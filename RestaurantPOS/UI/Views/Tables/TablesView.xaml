<UserControl x:Class="RestaurantPOS.UI.Views.Tables.TablesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:RestaurantPOS.UI.Views.Tables"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <ScrollViewer>
        <ItemsControl ItemsSource="{Binding Tables}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="4" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Margin="10"
                            Height="140"
                            Command="{Binding DataContext.SelectTableCommand,
                  RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                            CommandParameter="{Binding}"
                            Background="{Binding HasOrder, Converter={StaticResource BoolToBrushConverter}}"
                            BorderThickness="0"
                            Style="{StaticResource TableTileStyle}">
                        <TextBlock Text="{Binding Number}"
                                   FontSize="32"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>

                </DataTemplate>

            </ItemsControl.ItemTemplate>

        </ItemsControl>
    </ScrollViewer>
</UserControl>
