<UserControl x:Class="RestaurantPOS.UI.Views.Tables.TablesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d"
             d:DesignHeight="768"
             d:DesignWidth="1200">

    <Grid Background="{StaticResource BackgroundGray}">

        <!-- ══════════════════════════════════════════════════
             MAIN LAYOUT
             ══════════════════════════════════════════════════ -->
        <DockPanel>

            <!-- ── HEADER ── -->
            <Border DockPanel.Dock="Top"
                    Height="80"
                    Background="White"
                    BorderBrush="{StaticResource BorderGray}"
                    BorderThickness="0,0,0,1"
                    Padding="28,0">
                <Grid VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <iconPacks:PackIconMaterial Kind="TableChair"
                                                    Foreground="{StaticResource PrimaryAccent}"
                                                    Width="24"
                                                    Height="24"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,14,0" />
                        <TextBlock Text="TABLES"
                                   FontSize="22"
                                   FontWeight="Black"
                                   Foreground="{StaticResource TextDark}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Right side buttons — Admin/Manager only -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Visibility="{Binding CanManageTables,
                                             Converter={StaticResource BoolToVisibilityConverter}}">

                        <!-- Add Table button — only in edit mode -->
                        <Button Style="{StaticResource ModernButton}"
                                Command="{Binding AddTableCommand}"
                                Height="44"
                                Padding="20,0"
                                Margin="0,0,12,0"
                                Background="{StaticResource SuccessGreen}"
                                Foreground="White"
                                BorderThickness="0"
                                Visibility="{Binding IsEditMode,
                                             Converter={StaticResource BoolToVisibilityConverter}}">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius"
                                            Value="10" />
                                </Style>
                            </Button.Resources>
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="Plus"
                                                            Width="14"
                                                            Height="14"
                                                            VerticalAlignment="Center"
                                                            Margin="0,0,8,0" />
                                <TextBlock Text="Add Table"
                                           VerticalAlignment="Center"
                                           FontWeight="Bold"
                                           FontSize="14" />
                            </StackPanel>
                        </Button>

                        <!-- Edit Tables toggle -->
                        <Button Height="44"
                                Padding="20,0"
                                FontSize="14"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Command="{Binding ToggleEditModeCommand}">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius"
                                            Value="10" />
                                </Style>
                            </Button.Resources>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background"
                                            Value="#F1F5F9" />
                                    <Setter Property="Foreground"
                                            Value="{StaticResource TextDark}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditMode}"
                                                     Value="True">
                                            <Setter Property="Background"
                                                    Value="#FEF3C7" />
                                            <Setter Property="Foreground"
                                                    Value="#92400E" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Width="14"
                                                            Height="14"
                                                            VerticalAlignment="Center"
                                                            Margin="0,0,8,0">
                                    <iconPacks:PackIconMaterial.Style>
                                        <Style TargetType="iconPacks:PackIconMaterial">
                                            <Setter Property="Kind"
                                                    Value="Pencil" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditMode}"
                                                             Value="True">
                                                    <Setter Property="Kind"
                                                            Value="Check" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </iconPacks:PackIconMaterial.Style>
                                </iconPacks:PackIconMaterial>
                                <TextBlock Text="{Binding EditModeButtonLabel}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── EDIT MODE BANNER ── -->
            <Border DockPanel.Dock="Top"
                    Height="40"
                    Background="#FEF3C7"
                    Visibility="{Binding IsEditMode,
                                 Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <iconPacks:PackIconMaterial Kind="PencilCircle"
                                                Width="16"
                                                Height="16"
                                                Foreground="#92400E"
                                                VerticalAlignment="Center"
                                                Margin="0,0,8,0" />
                    <TextBlock Text="Edit Mode — tap a table to edit or delete it. Tap Done when finished."
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#92400E"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- ── TABLE GRID ── -->
            <ScrollViewer Padding="28,24"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Tables}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Width="160"
                                  Height="140"
                                  Margin="8">

                                <!-- ── TABLE TILE ── -->
                                <Button Height="120"
                                        Width="120"
                                        Command="{Binding DataContext.SelectTableCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                    <Button.Style>
                                        <Style TargetType="Button"
                                               BasedOn="{StaticResource MenuItemTile}">
                                            <Style.Triggers>

                                                <!-- Current table — blue border -->
                                                <DataTrigger Binding="{Binding IsCurrent}"
                                                             Value="True">
                                                    <Setter Property="BorderBrush"
                                                            Value="{StaticResource PrimaryAccent}" />
                                                    <Setter Property="BorderThickness"
                                                            Value="3" />
                                                </DataTrigger>

                                                <!-- Occupied — green tint -->
                                                <DataTrigger Binding="{Binding HasOrder}"
                                                             Value="True">
                                                    <Setter Property="Background"
                                                            Value="#F0FDF4" />
                                                </DataTrigger>

                                                <!-- Edit mode — amber tint -->
                                                <DataTrigger Binding="{Binding DataContext.IsEditMode,
                                                             RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                             Value="True">
                                                    <Setter Property="Background"
                                                            Value="#FFFBEB" />
                                                    <Setter Property="BorderBrush"
                                                            Value="#FCD34D" />
                                                    <Setter Property="BorderThickness"
                                                            Value="2" />
                                                </DataTrigger>

                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>

                                    <Grid>
                                        <StackPanel VerticalAlignment="Center">

                                            <!-- Table number -->
                                            <TextBlock Text="{Binding tableNumber}"
                                                       FontSize="36"
                                                       FontWeight="Black"
                                                       TextAlignment="Center"
                                                       Foreground="{StaticResource TextDark}" />

                                            <!-- "TABLE" label -->
                                            <TextBlock Text="TABLE"
                                                       FontSize="10"
                                                       FontWeight="Bold"
                                                       TextAlignment="Center"
                                                       Foreground="{StaticResource TextMuted}"
                                                       Margin="0,2,0,0" />

                                            <!-- Order total — only when occupied -->
                                            <TextBlock FontSize="13"
                                                       FontWeight="SemiBold"
                                                       TextAlignment="Center"
                                                       Margin="0,4,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility"
                                                                Value="Collapsed" />
                                                        <Setter Property="Foreground"
                                                                Value="{StaticResource SuccessGreen}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasOrder}"
                                                                         Value="True">
                                                                <Setter Property="Visibility"
                                                                        Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                                <Run Text="{Binding CurrencySymbol,
                                                     Mode=OneWay}" />
                                                <Run Text="{Binding CurrentTotal,
                                                     StringFormat={}{0:N2}, Mode=OneWay}" />
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Occupied dot — top right -->
                                        <Ellipse Width="10"
                                                 Height="10"
                                                 HorizontalAlignment="Right"
                                                 VerticalAlignment="Top"
                                                 Margin="0,8,8,0"
                                                 Fill="{StaticResource SuccessGreen}">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Visibility"
                                                            Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasOrder}"
                                                                     Value="True">
                                                            <Setter Property="Visibility"
                                                                    Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                    </Grid>
                                </Button>

                                <!-- ✅ EDIT BADGE — bottom-left — edit mode only -->
                                <Button Width="36"
                                        Height="36"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Bottom"
                                        Margin="6"
                                        Background="{StaticResource PrimaryAccent}"
                                        BorderThickness="0"
                                        Command="{Binding DataContext.EditTableCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Visibility="{Binding DataContext.IsEditMode,
                                                     RelativeSource={RelativeSource AncestorType=UserControl},
                                                     Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius"
                                                    Value="8" />
                                        </Style>
                                    </Button.Resources>
                                    <iconPacks:PackIconMaterial Kind="Pencil"
                                                                Width="14"
                                                                Height="14"
                                                                Foreground="White" />
                                </Button>

                                <!-- ✅ DELETE BADGE — bottom-right — edit mode only -->
                                <Button Width="36"
                                        Height="36"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom"
                                        Margin="6"
                                        Background="#DC2626"
                                        BorderThickness="0"
                                        Command="{Binding DataContext.DeleteTableCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Visibility="{Binding DataContext.IsEditMode,
                                                     RelativeSource={RelativeSource AncestorType=UserControl},
                                                     Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius"
                                                    Value="8" />
                                        </Style>
                                    </Button.Resources>
                                    <iconPacks:PackIconMaterial Kind="TrashCanOutline"
                                                                Width="14"
                                                                Height="14"
                                                                Foreground="White" />
                                </Button>

                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>

        <!-- ══════════════════════════════════════════════════════════════════
             TABLE EDITOR OVERLAY
             Numpad driven. Hardware keyboard also works via TextBox binding.
             ══════════════════════════════════════════════════════════════════ -->
        <Border Background="#CC1E293B"
                DataContext="{Binding Editor}"
                Visibility="{Binding IsOpen,
                             Converter={StaticResource BoolToVisibilityConverter}}">

            <Border Width="380"
                    Background="White"
                    CornerRadius="20"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="40"
                                      ShadowDepth="4"
                                      Opacity="0.15" />
                </Border.Effect>

                <StackPanel Margin="36,32">

                    <!-- Header -->
                    <Grid Margin="0,0,0,28">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <iconPacks:PackIconMaterial Kind="TableChair"
                                                        Foreground="{StaticResource PrimaryAccent}"
                                                        Width="20"
                                                        Height="20"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,12,0" />
                            <TextBlock Text="{Binding Title}"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextDark}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <Button HorizontalAlignment="Right"
                                Command="{Binding CancelCommand}"
                                Background="Transparent"
                                BorderThickness="0"
                                Width="36"
                                Height="36">
                            <iconPacks:PackIconMaterial Kind="Close"
                                                        Width="14"
                                                        Height="14"
                                                        Foreground="{StaticResource TextMuted}" />
                        </Button>
                    </Grid>

                    <!-- Table number label -->
                    <TextBlock Text="TABLE NUMBER"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextMuted}"
                               Margin="0,0,0,10" />

                    <!-- Display + TextBox overlay
                         The TextBox is transparent/invisible but receives
                         hardware keyboard input and stays in sync via binding.
                         The styled Border shows the value visually. -->
                    <Border Height="80"
                            CornerRadius="14"
                            BorderThickness="2"
                            BorderBrush="{StaticResource PrimaryAccent}"
                            Background="#F8FAFF"
                            Margin="0,0,0,24">
                        <Grid>
                            <!-- Hardware keyboard TextBox — transparent overlay -->
                            <TextBox Text="{Binding NumberDisplay, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="Transparent"
                                     CaretBrush="Transparent"
                                     FontSize="1"
                                     Padding="0"
                                     VerticalAlignment="Stretch"
                                     HorizontalAlignment="Stretch" />

                            <!-- Visual display -->
                            <TextBlock Text="{Binding NumberDisplay}"
                                       FontSize="42"
                                       FontWeight="Black"
                                       Foreground="{StaticResource PrimaryAccent}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False" />

                            <!-- Placeholder -->
                            <TextBlock Text="—"
                                       FontSize="36"
                                       FontWeight="Black"
                                       Foreground="#CBD5E1"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility"
                                                Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding NumberDisplay}"
                                                         Value="">
                                                <Setter Property="Visibility"
                                                        Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Numpad -->
                    <Border Background="#F8FAFC"
                            CornerRadius="14"
                            Padding="12"
                            Margin="0,0,0,24">
                        <StackPanel>
                            <UniformGrid Rows="3"
                                         Columns="3"
                                         Margin="0,0,0,8">
                                <Button Style="{StaticResource KeyboardKey}"
                                        Height="60"
                                        Command="{Binding NumpadKeyCommand}"
                                        CommandParameter="7" />
                                <Button Style="{StaticResource KeyboardKey}"
                                        Height="60"
                                        Command="{Binding NumpadKeyCommand}"
                                        CommandParameter="8" />
                                <Button Style="{StaticResource KeyboardKey}"
                                        Height="60"
                                        Command="{Binding NumpadKeyCommand}"
                                        CommandParameter="9" />
                                <Button Style="{StaticResource KeyboardKey}"
                                        Height="60"
                                        Command="{Binding NumpadKeyCommand}"
                                        CommandParameter="4" />
                                <Button Style="{StaticResource KeyboardKey}"
                                        Height="60"
                                        Command="{Binding NumpadKeyCommand}"
                                        CommandParameter="5" />
                                <Button Style="{StaticResource KeyboardKey}"
                                        Height="60"
                                        Command="{Binding NumpadKeyCommand}"
                                        CommandParameter="6" />
                                <Button Style="{StaticResource KeyboardKey}"
                                        Height="60"
                                        Command="{Binding NumpadKeyCommand}"
                                        CommandParameter="1" />
                                <Button Style="{StaticResource KeyboardKey}"
                                        Height="60"
                                        Command="{Binding NumpadKeyCommand}"
                                        CommandParameter="2" />
                                <Button Style="{StaticResource KeyboardKey}"
                                        Height="60"
                                        Command="{Binding NumpadKeyCommand}"
                                        CommandParameter="3" />
                            </UniformGrid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        Style="{StaticResource KeyboardKey}"
                                        Height="60"
                                        Command="{Binding ClearCommand}"
                                        Content="CLR" />
                                <Button Grid.Column="1"
                                        Style="{StaticResource KeyboardKey}"
                                        Height="60"
                                        Command="{Binding NumpadKeyCommand}"
                                        CommandParameter="0" />
                                <Button Grid.Column="2"
                                        Style="{StaticResource KeyboardKey}"
                                        Height="60"
                                        Command="{Binding BackspaceCommand}">
                                    <iconPacks:PackIconMaterial Kind="BackspaceOutline"
                                                                Width="18"
                                                                Height="18" />
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Save / Cancel -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Height="56"
                                FontSize="16"
                                FontWeight="Bold"
                                Background="#F1F5F9"
                                Foreground="{StaticResource TextDark}"
                                BorderThickness="0"
                                Command="{Binding CancelCommand}">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius"
                                            Value="12" />
                                </Style>
                            </Button.Resources>
                            <TextBlock Text="Cancel" />
                        </Button>

                        <Button Grid.Column="2"
                                Height="56"
                                FontSize="16"
                                FontWeight="Bold"
                                Background="{StaticResource PrimaryAccent}"
                                Foreground="White"
                                BorderThickness="0"
                                Command="{Binding SaveCommand}">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius"
                                            Value="12" />
                                </Style>
                            </Button.Resources>
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="ContentSave"
                                                            Width="16"
                                                            Height="16"
                                                            VerticalAlignment="Center"
                                                            Margin="0,0,8,0" />
                                <TextBlock Text="Save Table"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>

                </StackPanel>
            </Border>
        </Border>

    </Grid>
</UserControl>