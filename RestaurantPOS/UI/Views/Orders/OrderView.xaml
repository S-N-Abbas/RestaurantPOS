<UserControl x:Class="RestaurantPOS.UI.Views.Orders.OrderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:RestaurantPOS.UI.Views.Orders"
             xmlns:converter="clr-namespace:RestaurantPOS.UI.Converters"
             xmlns:views="clr-namespace:RestaurantPOS.UI.Views.Cover"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <DockPanel>

            <!-- Top Bar -->
            <Border DockPanel.Dock="Top"
                    Height="60"
                    Background="#1F2937"
                    Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding TableNumber, StringFormat=Table {0}}"
                               Foreground="White"
                               FontSize="22"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="1"
                            Style="{StaticResource TopBarButton}"
                            Content="Change Table"
                            HorizontalAlignment="Right"
                            Command="{Binding OpenTablePickerCommand}"/>
                    <Button Grid.Column="2"
                            Content="Covers"
                            Style="{StaticResource TopBarButton}"
                            HorizontalAlignment="Right"
                            Command="{Binding OpenCoverSelectorCommand}" />
                </Grid>
            </Border>

            <!-- Left: Categories -->
            <Border DockPanel.Dock="Left"
                    Width="200"
                    Background="#111827">
                <ListBox ItemsSource="{Binding Categories}"
                         SelectedItem="{Binding SelectedCategory}"
                         DisplayMemberPath="Name"
                         ItemContainerStyle="{StaticResource MenuItemTileListBoxItem}" />
            </Border>

            <!-- Right: Order Summary -->
            <Border DockPanel.Dock="Right"
                    Width="340"
                    Padding="16"
                    Background="#F9FAFB"
                    Style="{StaticResource OrderSummaryPanel}">
                <DockPanel LastChildFill="True">

                    <!-- Header -->
                    <TextBlock DockPanel.Dock="Top"
                               Text="Order Summary"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,12" />

                    <!-- ✅ COVERS SUMMARY -->
                    <Border DockPanel.Dock="Top"
                            Background="#EEF2FF"
                            CornerRadius="8"
                            Padding="10"
                            Margin="0,0,0,12">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Covers"
                                           FontWeight="Bold"
                                           FontSize="14" />

                                <TextBlock Text="{Binding CoversDisplay}"
                                           FontSize="13"
                                           Foreground="#374151" />
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Content="Edit"
                                    Padding="10,4"
                                    Margin="8,0,0,0"
                                    Command="{Binding OpenCoverSelectorCommand}" />
                        </Grid>
                    </Border>

                    <!-- Order Items -->
                    <ListView DockPanel.Dock="Top"
                              ItemsSource="{Binding OrderItems}"
                              Margin="0,0,0,12">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{Binding Name}"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold" />

                                    <Button Grid.Column="1"
                                            Content="−"
                                            Width="30"
                                            Command="{Binding DecreaseCommand}" />

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Quantity}"
                                               Width="30"
                                               TextAlignment="Center"
                                               VerticalAlignment="Center" />

                                    <Button Grid.Column="3"
                                            Content="+"
                                            Width="30"
                                            Command="{Binding IncreaseCommand}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Footer -->
                    <StackPanel DockPanel.Dock="Bottom"
                                Margin="0,12,0,0">

                        <Separator Margin="0,8" />

                        <TextBlock Text="{Binding GrandTotal, StringFormat=Total: Rs {0}}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="0,0,0,12" />

                        <!-- PAY BUTTON -->
                        <Button Content="PAY"
                                Height="48"
                                FontSize="18"
                                FontWeight="Bold"
                                Background="#16A34A"
                                Foreground="White"
                                BorderThickness="0"
                                Command="{Binding PayCommand}"
                                IsEnabled="{Binding CanPay}" />
                    </StackPanel>

                </DockPanel>
            </Border>

            <!-- Center: Items -->
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="4" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Height="100"
                                    Margin="8"
                                    Style="{StaticResource MenuItemTile}"
                                    Command="{Binding DataContext.AddItemCommand,
                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Price}" />
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

        </DockPanel>
        <!-- TABLE PICKER OVERLAY -->
        <Border Background="#AA000000"
                Visibility="{Binding IsTablePickerOpen,
                                 Converter={StaticResource BoolToVisibilityConverter}}">

            <Border Width="500"
                    Height="400"
                    Background="White"
                    CornerRadius="12"
                    Padding="20"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <ItemsControl ItemsSource="{Binding TablePicker.Tables}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="4" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button
                                Style="{StaticResource TableTileStyle}"
                                Height="80"
                                    Margin="8"
                                    Command="{Binding DataContext.TablePicker.SelectTableCommand,
                                                  RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}">
                                <TextBlock Text="{Binding Number}"
                                           FontSize="22"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </Border>
        </Border>
        <Border Background="#AA000000"
                Visibility="{Binding IsCoverSelectorOpen,
                     Converter={StaticResource BoolToVisibilityConverter}}">

            <views:CoverSelectorView
                DataContext="{Binding coverSelectorViewModel}"/>

        </Border>
    </Grid>
</UserControl>
