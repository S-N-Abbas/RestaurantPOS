<UserControl x:Class="RestaurantPOS.UI.Views.Orders.OrderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:RestaurantPOS.UI.Views.Orders"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <DockPanel>

        <!-- Top Bar -->
        <Border DockPanel.Dock="Top"
                Height="60"
                Background="#1F2937"
                Padding="16">
            <TextBlock Text="{Binding TableNumber, StringFormat=Table {0}}"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="SemiBold" />
        </Border>

        <!-- Left: Categories -->
        <Border DockPanel.Dock="Left"
                Width="200"
                Background="#111827">
            <ListBox ItemsSource="{Binding Categories}"
                     SelectedItem="{Binding SelectedCategory}"
                     DisplayMemberPath="Name" />
        </Border>

        <!-- Right: Order Summary -->
        <Border DockPanel.Dock="Right"
                Width="320"
                Padding="12"
                Background="#F9FAFB">
            <StackPanel>

                <TextBlock Text="Order"
                           FontSize="20"
                           FontWeight="Bold" />

                <ListView ItemsSource="{Binding OrderItems}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <DockPanel>
                                <TextBlock Text="{Binding Name}" />
                                <TextBlock Text="{Binding Total}"
                                           DockPanel.Dock="Right" />
                            </DockPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Separator />

                <TextBlock Text="{Binding GrandTotal, StringFormat=Total: Rs {0}}"
                           FontSize="18"
                           FontWeight="Bold" />
            </StackPanel>
        </Border>

        <!-- Center: Items -->
        <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Items}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="4" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Height="100"
                                Margin="8"
                                Command="{Binding DataContext.AddItemCommand,
                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                CommandParameter="{Binding}">
                            <StackPanel>
                                <TextBlock Text="{Binding Name}"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Price}" />
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>
</UserControl>
