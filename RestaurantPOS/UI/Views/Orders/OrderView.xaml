<UserControl x:Class="RestaurantPOS.UI.Views.Orders.OrderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:RestaurantPOS.UI.Views.Orders"
             xmlns:converter="clr-namespace:RestaurantPOS.UI.Converters"
             xmlns:views="clr-namespace:RestaurantPOS.UI.Views.Cover"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="{StaticResource BackgroundGray}">
        <DockPanel>
            <Border DockPanel.Dock="Top"
                    Height="80"
                    Background="White"
                    BorderBrush="{StaticResource BorderGray}"
                    BorderThickness="0,0,0,1"
                    Padding="24,0">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <iconPacks:PackIconMaterial Kind="TableChair"
                                                    Foreground="{StaticResource PrimaryAccent}"
                                                    VerticalAlignment="Center"
                                                    Width="24"
                                                    Height="24"
                                                    Margin="0,0,12,0" />
                        <TextBlock Text="{Binding TableNumber, StringFormat=TABLE {0}}"
                                   FontSize="28"
                                   FontWeight="Black"
                                   Foreground="{StaticResource TextDark}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal">
                        <Button Style="{StaticResource ModernButton}"
                                Command="{Binding OpenTablePickerCommand}"
                                Margin="0,0,12,0">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="SwapHorizontal"
                                                            Margin="0,0,8,0"
                                                            VerticalAlignment="Center"
                                                            Width="14" />
                                <TextBlock Text="Switch Table"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource ModernButton}"
                                Command="{Binding OpenCoverSelectorCommand}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="AccountGroup"
                                                            Margin="0,0,8,0"
                                                            VerticalAlignment="Center"
                                                            Width="14" />
                                <TextBlock Text="Manage Covers"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border DockPanel.Dock="Left"
                    Width="240"
                    Background="White"
                    BorderBrush="{StaticResource BorderGray}"
                    BorderThickness="0,0,1,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="CATEGORIES"
                               Margin="20,20,20,10"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextMuted}"
                                />
                    <ListBox ItemsSource="{Binding Categories}"
                             SelectedItem="{Binding SelectedCategory}"
                             DisplayMemberPath="Name"
                             ItemContainerStyle="{StaticResource CategoryListBoxItem}"
                             Background="Transparent"
                             BorderThickness="0"
                             Margin="10,0" />
                </DockPanel>
            </Border>

            <Border DockPanel.Dock="Right"
                    Width="380"
                    Margin="20"
                    Background="White"
                    CornerRadius="16"
                    BorderBrush="{StaticResource BorderGray}"
                    BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20"
                                      ShadowDepth="2"
                                      Opacity="0.05" />
                </Border.Effect>

                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Current Order"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextDark}"
                               Margin="0,0,0,15" />

                    <Border Grid.Row="1"
                            Background="#F8FAFC"
                            CornerRadius="8"
                            Padding="12"
                            Margin="0,0,0,15">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="Account"
                                                            Foreground="{StaticResource TextMuted}"
                                                            VerticalAlignment="Center"
                                                            Width="14"
                                                            Margin="0,0,8,0" />
                                <TextBlock Text="{Binding CoversDisplay, StringFormat='{}Guests: {0}'}"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource TextMuted}"
                                           FontWeight="Medium" />
                            </StackPanel>
                            <Button HorizontalAlignment="Right"
                                    Content="Edit"
                                    FontSize="11"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="{StaticResource PrimaryAccent}"
                                    Command="{Binding OpenCoverSelectorCommand}" />
                        </Grid>
                    </Border>

                    <ListView Grid.Row="2"
                              ItemsSource="{Binding OrderItems}"
                              BorderThickness="0"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              HorizontalContentAlignment="Stretch">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource BorderGray}"
                                        BorderThickness="0,0,0,1"
                                        Padding="4,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel VerticalAlignment="Center"
                                                    Margin="0,0,16,0">
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource TextDark}"
                                                       FontSize="15"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Price, StringFormat='£{0:N2}'}"
                                                       Foreground="{StaticResource TextMuted}"
                                                       FontSize="13"
                                                       Margin="0,2,0,0" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">

                                            <Button Style="{StaticResource CircleActionButton}"
                                                    Command="{Binding DecreaseCommand}"
                                                    Content="−" />

                                            <TextBlock Text="{Binding Quantity}"
                                                       Width="40"
                                                       TextAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontWeight="Black"
                                                       Foreground="{StaticResource PrimaryAccent}"
                                                       FontSize="16"
                                                       Margin="4,0" />

                                            <Button Style="{StaticResource CircleActionButton}"
                                                    Command="{Binding IncreaseCommand}"
                                                    Content="+" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <StackPanel Grid.Row="3"
                                Margin="0,15,0,0">
                        <Separator Background="{StaticResource BorderGray}"
                                   Margin="0,0,0,15" />
                        <Grid Margin="0,0,0,20">
                            <TextBlock Text="Total Payable"
                                       FontSize="14"
                                       Foreground="{StaticResource TextMuted}"
                                       VerticalAlignment="Bottom" />
                            <TextBlock Text="{Binding GrandTotal, StringFormat='£{0:N2}'}"
                                       FontSize="32"
                                       FontWeight="Black"
                                       Foreground="{StaticResource TextDark}"
                                       HorizontalAlignment="Right" />
                        </Grid>

                        <Button Content="PROCESS PAYMENT"
                                Height="65"
                                FontSize="18"
                                FontWeight="Bold"
                                Background="{StaticResource SuccessGreen}"
                                Foreground="White"
                                BorderThickness="0"
                                Command="{Binding PayCommand}"
                                IsEnabled="{Binding CanPay}">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius"
                                            Value="12" />
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Margin="10,20,0,20"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="4" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource MenuItemTile}"
                                    Height="130"
                                    Command="{Binding DataContext.AddItemCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}">
                                <Grid>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}"
                                                   TextAlignment="Center"
                                                   FontWeight="Bold"
                                                   FontSize="16"
                                                   Foreground="{StaticResource TextDark}"
                                                   TextWrapping="Wrap"
                                                   MaxHeight="60" />
                                        <TextBlock Text="{Binding Price, StringFormat='£{0:N2}'}"
                                                   TextAlignment="Center"
                                                   Margin="0,8,0,0"
                                                   Foreground="{StaticResource PrimaryAccent}"
                                                   FontWeight="SemiBold" />
                                    </StackPanel>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>

        <Border Background="#CC1E293B"
                Visibility="{Binding IsTablePickerOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Width="600"
                    Background="White"
                    CornerRadius="20"
                    Padding="30"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Select a Table"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0,0,0,20"
                               HorizontalAlignment="Center" />
                    <ItemsControl ItemsSource="{Binding TablePicker.Tables}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource MenuItemTile}"
                                        Height="80"
                                        Command="{Binding DataContext.TablePicker.SelectTableCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}">
                                    <TextBlock Text="{Binding Number}"
                                               FontSize="22"
                                               FontWeight="Bold" />
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Border>

        <Border Background="#CC1E293B"
                Visibility="{Binding IsCoverSelectorOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <views:CoverSelectorView DataContext="{Binding coverSelectorViewModel}"
                                     VerticalAlignment="Center"
                                     HorizontalAlignment="Center" />
        </Border>
    </Grid>
</UserControl>
