<UserControl x:Class="RestaurantPOS.UI.Views.Orders.OrderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:RestaurantPOS.UI.Views.Orders"
             xmlns:converter="clr-namespace:RestaurantPOS.UI.Converters"
             xmlns:views="clr-namespace:RestaurantPOS.UI.Views.Cover"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d"
             d:DesignHeight="900"
             d:DesignWidth="1300">
    <Grid Background="{StaticResource BackgroundGray}">
        <DockPanel>

            <!-- ══════════════════════════════════════════════════════
                 TOP HEADER BAR
                 Now shows ContextLabel instead of raw TableNumber,
                 and "Switch Order" instead of "Switch Table"
                 ══════════════════════════════════════════════════════ -->
            <Border DockPanel.Dock="Top"
                    Height="80"
                    Background="White"
                    BorderBrush="{StaticResource BorderGray}"
                    BorderThickness="0,0,0,1"
                    Padding="24,0">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Context Label: "TABLE 3" / "TAKEAWAY #1" / "DELIVERY #2" -->
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <iconPacks:PackIconMaterial Kind="{Binding ContextIcon}"
                                                    Foreground="{StaticResource PrimaryAccent}"
                                                    VerticalAlignment="Center"
                                                    Width="24"
                                                    Height="24"
                                                    Margin="0,0,12,0" />
                        <TextBlock Text="{Binding ContextLabel}"
                                   FontSize="28"
                                   FontWeight="Black"
                                   Foreground="{StaticResource TextDark}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal">
                        <!-- Renamed from "Switch Table" to "Switch Order" -->
                        <Button Style="{StaticResource ModernButton}"
                                Command="{Binding OpenOrderSwitcherCommand}"
                                Margin="0,0,12,0">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="SwapHorizontal"
                                                            Margin="0,0,8,0"
                                                            VerticalAlignment="Center"
                                                            Width="14" />
                                <TextBlock Text="Switch Order"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource ModernButton}"
                                Command="{Binding OpenCoverSelectorCommand}"
                                Visibility="{Binding IsDineIn,
                     Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="AccountGroup"
                                                            Margin="0,0,8,0"
                                                            VerticalAlignment="Center"
                                                            Width="14" />
                                <TextBlock Text="Manage Covers"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Categories, Order Panel, Menu Items — UNCHANGED -->
            <Border DockPanel.Dock="Left"
                    Width="240"
                    Background="White"
                    BorderBrush="{StaticResource BorderGray}"
                    BorderThickness="0,0,1,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="CATEGORIES"
                               Margin="20,20,20,10"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextMuted}" />

                    <!-- ✅ + Add Category button — Admin/Manager only -->
                    <Button DockPanel.Dock="Bottom"
                            Height="52"
                            Margin="10,8"
                            Command="{Binding AddCategoryCommand}"
                            Visibility="{Binding CanEditMenu,
                             Converter={StaticResource BoolToVisibilityConverter}}"
                            Background="#F0FDF4"
                            Foreground="#16A34A"
                            BorderBrush="#BBF7D0"
                            BorderThickness="1"
                            FontWeight="Bold"
                            FontSize="13">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius"
                                        Value="10" />
                            </Style>
                        </Button.Resources>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Plus"
                                                        Width="14"
                                                        Height="14"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,8,0" />
                            <TextBlock Text="Add Category"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <ListBox ItemsSource="{Binding Categories}"
                             SelectedItem="{Binding SelectedCategory}"
                             DisplayMemberPath="Name"
                             ItemContainerStyle="{StaticResource CategoryListBoxItem}"
                             Background="Transparent"
                             BorderThickness="0"
                             Margin="10,0" />
                </DockPanel>
            </Border>

            <Border DockPanel.Dock="Right"
                    Width="380"
                    Margin="20"
                    Background="White"
                    CornerRadius="16"
                    BorderBrush="{StaticResource BorderGray}"
                    BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20"
                                      ShadowDepth="2"
                                      Opacity="0.05" />
                </Border.Effect>
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Current Order"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextDark}"
                               Margin="0,0,0,15" />

                    <Border Grid.Row="1"
                            Background="#F8FAFC"
                            CornerRadius="8"
                            Padding="12"
                            Margin="0,0,0,15"
                            Visibility="{Binding IsDineIn, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="Account"
                                                            Foreground="{StaticResource TextMuted}"
                                                            VerticalAlignment="Center"
                                                            Width="14"
                                                            Margin="0,0,8,0" />
                                <TextBlock Text="{Binding CoversDisplay, StringFormat='{}Guests: {0}'}"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource TextMuted}"
                                           FontWeight="Medium" />
                            </StackPanel>
                            <Button HorizontalAlignment="Right"
                                    Content="Edit"
                                    FontSize="11"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="{StaticResource PrimaryAccent}"
                                    Command="{Binding OpenCoverSelectorCommand}" />
                        </Grid>
                    </Border>

                    <ListView Grid.Row="2"
                              ItemsSource="{Binding OrderItems}"
                              BorderThickness="0"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              HorizontalContentAlignment="Stretch">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource BorderGray}"
                                        BorderThickness="0,0,0,1"
                                        Padding="4,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center"
                                                    Margin="0,0,16,0">
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource TextDark}"
                                                       FontSize="15"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding UnitPrice, StringFormat='£{0:N2}'}"
                                                       Foreground="{StaticResource TextMuted}"
                                                       FontSize="13"
                                                       Margin="0,2,0,0" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <Button Style="{StaticResource CircleActionButton}"
                                                    Command="{Binding DecreaseCommand}"
                                                    Content="−" />
                                            <TextBlock Text="{Binding Quantity}"
                                                       Width="40"
                                                       TextAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontWeight="Black"
                                                       Foreground="{StaticResource PrimaryAccent}"
                                                       FontSize="16"
                                                       Margin="4,0" />
                                            <Button Style="{StaticResource CircleActionButton}"
                                                    Command="{Binding IncreaseCommand}"
                                                    Content="+" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <StackPanel Grid.Row="3"
                                Margin="0,15,0,0">
                        <Separator Background="{StaticResource BorderGray}"
                                   Margin="0,0,0,15" />

                        <!-- Grand Total -->
                        <Grid Margin="0,0,0,20">
                            <TextBlock Text="Total Payable"
                                       FontSize="14"
                                       Foreground="{StaticResource TextMuted}"
                                       VerticalAlignment="Bottom" />
                            <TextBlock Text="{Binding GrandTotal, StringFormat='£{0:N2}'}"
                                       FontSize="32"
                                       FontWeight="Black"
                                       Foreground="{StaticResource TextDark}"
                                       HorizontalAlignment="Right" />
                        </Grid>

                        <!-- ✅ Two-button row: Cancel (left) + Pay (right) -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Cancel Order — only shown when an order exists -->
                            <Button Grid.Column="0"
                                    Width="110"
                                    Height="65"
                                    FontSize="13"
                                    FontWeight="Bold"
                                    Background="#FEE2E2"
                                    Foreground="#DC2626"
                                    BorderBrush="#FECACA"
                                    BorderThickness="1"
                                    Command="{Binding CancelOrderCommand}"
                                    Visibility="{Binding CanCancel,
                             Converter={StaticResource BoolToVisibilityConverter}}">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius"
                                                Value="12" />
                                    </Style>
                                </Button.Resources>
                                <StackPanel VerticalAlignment="Center">
                                    <iconPacks:PackIconMaterial Kind="CloseCircleOutline"
                                                                Width="18"
                                                                Height="18"
                                                                HorizontalAlignment="Center"
                                                                Margin="0,0,0,4" />
                                    <TextBlock Text="Cancel Order"
                                               TextAlignment="Center"
                                               FontSize="12"
                                               FontWeight="Bold" />
                                </StackPanel>
                            </Button>

                            <!-- Process Payment -->
                            <Button Grid.Column="2"
                                    Height="65"
                                    FontSize="18"
                                    FontWeight="Bold"
                                    Background="{StaticResource SuccessGreen}"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Command="{Binding PayCommand}"
                                    IsEnabled="{Binding CanPay}">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius"
                                                Value="12" />
                                    </Style>
                                </Button.Resources>
                                <TextBlock Text="PROCESS PAYMENT"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center" />
                            </Button>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Margin="10,20,0,20"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="4" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <!-- ✅ + Add Product tile — Admin/Manager only, first in grid -->
                    <Button Style="{StaticResource MenuItemTile}"
                            Height="130"
                            Command="{Binding AddProductCommand}"
                            Visibility="{Binding CanEditMenu,
                             Converter={StaticResource BoolToVisibilityConverter}}"
                            Background="#F0FDF4"
                            BorderBrush="#BBF7D0"
                            BorderThickness="2">
                        <StackPanel VerticalAlignment="Center">
                            <iconPacks:PackIconMaterial Kind="Plus"
                                                        Width="28"
                                                        Height="28"
                                                        HorizontalAlignment="Center"
                                                        Foreground="#16A34A"
                                                        Margin="0,0,0,8" />
                            <TextBlock Text="Add Product"
                                       TextAlignment="Center"
                                       FontWeight="Bold"
                                       FontSize="14"
                                       Foreground="#16A34A" />
                        </StackPanel>
                    </Button>

                    <!-- Existing products -->
                    <ItemsControl ItemsSource="{Binding Items}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <!-- Use WrapPanel inside so it flows after the + tile -->
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource MenuItemTile}"
                                        Height="130"
                                        Width="160"
                                        Margin="4"
                                        Command="{Binding DataContext.AddItemCommand,
                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                    <Grid>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       TextAlignment="Center"
                                                       FontWeight="Bold"
                                                       FontSize="16"
                                                       Foreground="{StaticResource TextDark}"
                                                       TextWrapping="Wrap"
                                                       MaxHeight="60" />
                                            <TextBlock Text="{Binding Price, StringFormat='£{0:N2}'}"
                                                       TextAlignment="Center"
                                                       Margin="0,8,0,0"
                                                       Foreground="{StaticResource PrimaryAccent}"
                                                       FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>

        <!-- ══════════════════════════════════════════════════════════════════
             ORDER SWITCHER OVERLAY  (replaces old "Select a Table" overlay)
             Three sections: Dine-In | TakeAway | Delivery
             ══════════════════════════════════════════════════════════════════ -->
        <Border Background="#CC1E293B"
                Visibility="{Binding IsOrderSwitcherOpen,
                             Converter={StaticResource BoolToVisibilityConverter}}">

            <!-- Modal card — scrollable so it never clips on small screens -->
            <Border Width="680"
                    MaxHeight="680"
                    Background="White"
                    CornerRadius="20"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="40"
                                      ShadowDepth="4"
                                      Opacity="0.15" />
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <!-- Header -->
                        <RowDefinition Height="*" />
                        <!-- Scrollable content -->
                        <RowDefinition Height="Auto" />
                        <!-- Action buttons -->
                    </Grid.RowDefinitions>

                    <!-- ── Modal Header ── -->
                    <Border Grid.Row="0"
                            BorderBrush="{StaticResource BorderGray}"
                            BorderThickness="0,0,0,1"
                            Padding="28,20">
                        <Grid>
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <iconPacks:PackIconMaterial Kind="SwapHorizontal"
                                                            Foreground="{StaticResource PrimaryAccent}"
                                                            Width="20"
                                                            Height="20"
                                                            VerticalAlignment="Center"
                                                            Margin="0,0,12,0" />
                                <TextBlock Text="Switch Order"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource TextDark}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <!-- Close button -->
                            <Button HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Command="{Binding CloseOrderSwitcherCommand}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Width="36"
                                    Height="36">
                                <iconPacks:PackIconMaterial Kind="Close"
                                                            Width="14"
                                                            Height="14"
                                                            Foreground="{StaticResource TextMuted}" />
                            </Button>
                        </Grid>
                    </Border>

                    <!-- ── Scrollable Sections ── -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="28,20">
                        <StackPanel>

                            <!-- ─ SECTION 1: DINE-IN TABLES ─ -->
                            <TextBlock Text="DINE-IN TABLES"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextMuted}"
                                       Margin="0,0,0,12"
                                        />

                            <ItemsControl ItemsSource="{Binding OrderSwitcher.Tables}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="5" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <!-- Table slot card -->
                                        <Button Height="80"
                                                Margin="4"
                                                Command="{Binding SelectTableCommand}"
                                                >
                                            <Button.Style>
                                                <Style TargetType="Button"
                                                       BasedOn="{StaticResource MenuItemTile}">
                                                    <Style.Triggers>
                                                        <!-- Active/current table gets accent border -->
                                                        <DataTrigger Binding="{Binding IsCurrent}"
                                                                     Value="True">
                                                            <Setter Property="BorderBrush"
                                                                    Value="{StaticResource PrimaryAccent}" />
                                                            <Setter Property="BorderThickness"
                                                                    Value="2" />
                                                        </DataTrigger>
                                                        <!-- Occupied-by-other dims the card -->
                                                        <DataTrigger Binding="{Binding IsLocked}"
                                                                     Value="True">
                                                            <Setter Property="Opacity"
                                                                    Value="0.4" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding tableNumber}"
                                                           FontSize="20"
                                                           FontWeight="Black"
                                                           TextAlignment="Center"
                                                           Foreground="{StaticResource TextDark}" />
                                                <!-- Show total only when occupied -->
                                                <TextBlock FontSize="11"
                                                           TextAlignment="Center"
                                                           Foreground="{StaticResource PrimaryAccent}"
                                                           FontWeight="SemiBold"
                                                           Margin="0,2,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility"
                                                                    Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasOrder}"
                                                                             Value="True">
                                                                    <Setter Property="Visibility"
                                                                            Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                    <Run Text="£" />
                                                    <Run Text="{Binding CurrentTotal, StringFormat={}{0:N2}, Mode=OneWay}" />
                                                </TextBlock>
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- ─ SECTION 2: TAKEAWAY SLOTS ─
                                 Entire section hidden when no slots are open -->
                            <StackPanel Margin="0,24,0,0"
                                        Visibility="{Binding OrderSwitcher.HasTakeAwaySlots,
                                                     Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="TAKEAWAY"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource TextMuted}"
                                           Margin="0,0,0,12" />

                                <ItemsControl ItemsSource="{Binding OrderSwitcher.TakeAwaySlots}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Height="80"
                                                    Width="120"
                                                    Margin="4"
                                                    Command="{Binding SelectSlotCommand}">
                                                <Button.Style>
                                                    <Style TargetType="Button"
                                                           BasedOn="{StaticResource MenuItemTile}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCurrent}"
                                                                         Value="True">
                                                                <Setter Property="BorderBrush"
                                                                        Value="{StaticResource PrimaryAccent}" />
                                                                <Setter Property="BorderThickness"
                                                                        Value="2" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <StackPanel VerticalAlignment="Center">
                                                    <iconPacks:PackIconMaterial Kind="BagPersonal"
                                                                                Width="16"
                                                                                Height="16"
                                                                                HorizontalAlignment="Center"
                                                                                Foreground="{StaticResource TextMuted}"
                                                                                Margin="0,0,0,4" />
                                                    <TextBlock Text="{Binding SlotLabel}"
                                                               FontSize="14"
                                                               FontWeight="Bold"
                                                               TextAlignment="Center"
                                                               Foreground="{StaticResource TextDark}" />
                                                    <TextBlock FontSize="11"
                                                               TextAlignment="Center"
                                                               Foreground="{StaticResource PrimaryAccent}"
                                                               FontWeight="SemiBold"
                                                               Margin="0,2,0,0">
                                                        <Run Text="£" />
                                                        <Run Text="{Binding CurrentTotal, StringFormat={}{0:N2}, Mode=OneWay}" />
                                                    </TextBlock>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <!-- ─ SECTION 3: DELIVERY SLOTS ─
                                 Entire section hidden when no slots are open -->
                            <StackPanel Margin="0,24,0,0"
                                        Visibility="{Binding OrderSwitcher.HasDeliverySlots,
                                                     Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="DELIVERY"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource TextMuted}"
                                           Margin="0,0,0,12" />

                                <ItemsControl ItemsSource="{Binding OrderSwitcher.DeliverySlots}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Height="80"
                                                    Width="120"
                                                    Margin="4"
                                                    Command="{Binding SelectSlotCommand}">
                                                <Button.Style>
                                                    <Style TargetType="Button"
                                                           BasedOn="{StaticResource MenuItemTile}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCurrent}"
                                                                         Value="True">
                                                                <Setter Property="BorderBrush"
                                                                        Value="{StaticResource PrimaryAccent}" />
                                                                <Setter Property="BorderThickness"
                                                                        Value="2" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <StackPanel VerticalAlignment="Center">
                                                    <iconPacks:PackIconMaterial Kind="Moped"
                                                                                Width="16"
                                                                                Height="16"
                                                                                HorizontalAlignment="Center"
                                                                                Foreground="{StaticResource TextMuted}"
                                                                                Margin="0,0,0,4" />
                                                    <TextBlock Text="{Binding SlotLabel}"
                                                               FontSize="14"
                                                               FontWeight="Bold"
                                                               TextAlignment="Center"
                                                               Foreground="{StaticResource TextDark}" />
                                                    <TextBlock FontSize="11"
                                                               TextAlignment="Center"
                                                               Foreground="{StaticResource PrimaryAccent}"
                                                               FontWeight="SemiBold"
                                                               Margin="0,2,0,0">
                                                        <Run Text="£" />
                                                        <Run Text="{Binding CurrentTotal, StringFormat={}{0:N2}, Mode=OneWay}" />
                                                    </TextBlock>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- ── Bottom Action Buttons: New TakeAway / New Delivery ── -->
                    <Border Grid.Row="2"
                            BorderBrush="{StaticResource BorderGray}"
                            BorderThickness="0,1,0,0"
                            Padding="28,16">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button Style="{StaticResource ModernButton}"
                                    Command="{Binding OrderSwitcher.NewTakeAwayCommand}"
                                    Margin="0,0,12,0">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="BagPersonal"
                                                                Width="14"
                                                                Height="14"
                                                                VerticalAlignment="Center"
                                                                Margin="0,0,8,0" />
                                    <TextBlock Text="New TakeAway"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource ModernButton}"
                                    Command="{Binding OrderSwitcher.NewDeliveryCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="Moped"
                                                                Width="14"
                                                                Height="14"
                                                                VerticalAlignment="Center"
                                                                Margin="0,0,8,0" />
                                    <TextBlock Text="New Delivery"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                </Grid>
            </Border>
        </Border>

        <!-- Cover Selector Overlay — unchanged -->
        <Border Background="#CC1E293B"
                Visibility="{Binding IsCoverSelectorOpen,
                             Converter={StaticResource BoolToVisibilityConverter}}">
            <views:CoverSelectorView DataContext="{Binding coverSelectorViewModel}"
                                     VerticalAlignment="Center"
                                     HorizontalAlignment="Center" />
        </Border>

        <!-- ══════════════════════════════════════════════════════════════
     INLINE MENU EDITOR OVERLAY
     Appears over everything. DataContext is MenuEditor on OrderViewModel.
     ══════════════════════════════════════════════════════════════ -->
        <Border Background="#CC1E293B"
                DataContext="{Binding MenuEditor}"
                Visibility="{Binding IsOpen,
                     Converter={StaticResource BoolToVisibilityConverter}}">

            <Border Width="700"
                    Background="White"
                    CornerRadius="20"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="40"
                                      ShadowDepth="4"
                                      Opacity="0.15" />
                </Border.Effect>

                <StackPanel Margin="36,32">

                    <!-- ── Header ── -->
                    <Grid Margin="0,0,0,24">
                        <TextBlock Text="{Binding Title}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextDark}"
                                   VerticalAlignment="Center" />
                        <Button HorizontalAlignment="Right"
                                Command="{Binding CancelCommand}"
                                Background="Transparent"
                                BorderThickness="0"
                                Width="36"
                                Height="36">
                            <iconPacks:PackIconMaterial Kind="Close"
                                                        Width="14"
                                                        Height="14"
                                                        Foreground="{StaticResource TextMuted}" />
                        </Button>
                    </Grid>

                    <!-- ── Name field (tappable, keyboard targets it) ── -->
                    <TextBlock Text="Name"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextMuted}"
                               Margin="0,0,0,6" />
                    <Border Height="56"
                            BorderThickness="2"
                            CornerRadius="12"
                            Margin="0,0,0,16">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="BorderBrush"
                                        Value="{StaticResource BorderGray}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNameActive}"
                                                 Value="True">
                                        <Setter Property="BorderBrush"
                                                Value="{StaticResource PrimaryAccent}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Button Command="{Binding FocusNameCommand}"
                                Background="Transparent"
                                BorderThickness="0"
                                HorizontalContentAlignment="Left"
                                Padding="16,0">
                            <TextBlock Text="{Binding Name}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextDark}"
                                       VerticalAlignment="Center" />
                        </Button>
                    </Border>

                    <!-- ── Price field — Product only ── -->
                    <StackPanel Visibility="{Binding IsProductMode,
                                     Converter={StaticResource BoolToVisibilityConverter}}"
                                Margin="0,0,0,16">
                        <TextBlock Text="Price (£)"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="0,0,0,6" />
                        <Border Height="56"
                                BorderThickness="2"
                                CornerRadius="12">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush"
                                            Value="{StaticResource BorderGray}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPriceActive}"
                                                     Value="True">
                                            <Setter Property="BorderBrush"
                                                    Value="{StaticResource PrimaryAccent}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Button Command="{Binding FocusPriceCommand}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    HorizontalContentAlignment="Left"
                                    Padding="16,0">
                                <TextBlock Text="{Binding Price}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextDark}"
                                           VerticalAlignment="Center" />
                            </Button>
                        </Border>
                    </StackPanel>

                    <!-- ── Category picker — Product only ── -->
                    <StackPanel Visibility="{Binding IsProductMode,
                                     Converter={StaticResource BoolToVisibilityConverter}}"
                                Margin="0,0,0,20">
                        <TextBlock Text="Category"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="0,0,0,8" />
                        <ItemsControl ItemsSource="{Binding Categories}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Height="40"
                                            Padding="16,0"
                                            Margin="0,0,8,8"
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            BorderThickness="1"
                                            Command="{Binding DataContext.SelectCategoryCommand,
                          RelativeSource={RelativeSource AncestorType=Border}}"
                                            CommandParameter="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background"
                                                        Value="#F8FAFC" />
                                                <Setter Property="BorderBrush"
                                                        Value="{StaticResource BorderGray}" />
                                                <Setter Property="Foreground"
                                                        Value="{StaticResource TextDark}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}"
                                                                 Value="True">
                                                        <Setter Property="Background"
                                                                Value="{StaticResource PrimaryAccent}" />
                                                        <Setter Property="Foreground"
                                                                Value="White" />
                                                        <Setter Property="BorderBrush"
                                                                Value="{StaticResource PrimaryAccent}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius"
                                                        Value="8" />
                                            </Style>
                                        </Button.Resources>
                                        <TextBlock Text="{Binding Name}" />
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- ── On-screen keyboard ── -->
                    <Border Background="#F8FAFC"
                            CornerRadius="12"
                            Padding="12"
                            Margin="0,0,0,24">
                        <StackPanel>
                            <!-- Row 1: Q W E R T Y U I O P -->
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Margin="0,0,0,6">
                                <Button Style="{StaticResource KeyboardKey}"
                                        Command="{Binding KeyCommand}"
                                        CommandParameter="Q" />
                                <Button Style="{StaticResource KeyboardKey}"
                                        Command="{Binding KeyCommand}"
                                        CommandParameter="W" />
                                <Button Style="{StaticResource KeyboardKey}"
                                        Command="{Binding KeyCommand}"
                                        CommandParameter="E" />
                                <Button Style="{StaticResource KeyboardKey}"
                                        Command="{Binding KeyCommand}"
                                        CommandParameter="R" />
                                <Button Style="{StaticResource KeyboardKey}"
                                        Command="{Binding KeyCommand}"
                                        CommandParameter="T" />
                                <Button Style="{StaticResource KeyboardKey}"
                                        Command="{Binding KeyCommand}"
                                        CommandParameter="Y" />
                                <Button Style="{StaticResource KeyboardKey}"
                                        Command="{Binding KeyCommand}"
                                        CommandParameter="U" />
                                <Button Style="{StaticResource KeyboardKey}"
                                        Command="{Binding KeyCommand}"
                                        CommandParameter="I" />
                                <Button Style="{StaticResource KeyboardKey}"
                                        Command="{Binding KeyCommand}"
                                        CommandParameter="O" />
                                <Button Style="{StaticResource KeyboardKey}"
                                        Command="{Binding KeyCommand}"
                                        CommandParameter="P" />
                            </StackPanel>
                            <!-- Row 2: A S D F G H J K L -->
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Margin="0,0,0,6">
                                <Button Style="{StaticResource KeyboardKey}"
                                        Command="{Binding KeyCommand}"
                                        CommandParameter="A" />
                                <Button Style="{StaticResource KeyboardKey}"
                                        Command="{Binding KeyCommand}"
                                        CommandParameter="S" />
                                <Button Style="{StaticResource KeyboardKey}"
                                        Command="{Binding KeyCommand}"
                                        CommandParameter="D" />
                                <Button Style="{StaticResource KeyboardKey}"
                                        Command="{Binding KeyCommand}"
                                        CommandParameter="F" />
                                <Button Style="{StaticResource KeyboardKey}"
                                        Command="{Binding KeyCommand}"
                                        CommandParameter="G" />
                                <Button Style="{StaticResource KeyboardKey}"
                                        Command="{Binding KeyCommand}"
                                        CommandParameter="H" />
                                <Button Style="{StaticResource KeyboardKey}"
                                        Command="{Binding KeyCommand}"
                                        CommandParameter="J" />
                                <Button Style="{StaticResource KeyboardKey}"
                                        Command="{Binding KeyCommand}"
                                        CommandParameter="K" />
                                <Button Style="{StaticResource KeyboardKey}"
                                        Command="{Binding KeyCommand}"
                                        CommandParameter="L" />
                            </StackPanel>
                            <!-- Row 3: Z X C V B N M + Space -->
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Margin="0,0,0,6">
                                <Button Style="{StaticResource KeyboardKey}"
                                        Command="{Binding KeyCommand}"
                                        CommandParameter="Z" />
                                <Button Style="{StaticResource KeyboardKey}"
                                        Command="{Binding KeyCommand}"
                                        CommandParameter="X" />
                                <Button Style="{StaticResource KeyboardKey}"
                                        Command="{Binding KeyCommand}"
                                        CommandParameter="C" />
                                <Button Style="{StaticResource KeyboardKey}"
                                        Command="{Binding KeyCommand}"
                                        CommandParameter="V" />
                                <Button Style="{StaticResource KeyboardKey}"
                                        Command="{Binding KeyCommand}"
                                        CommandParameter="B" />
                                <Button Style="{StaticResource KeyboardKey}"
                                        Command="{Binding KeyCommand}"
                                        CommandParameter="N" />
                                <Button Style="{StaticResource KeyboardKey}"
                                        Command="{Binding KeyCommand}"
                                        CommandParameter="M" />
                                <Button Style="{StaticResource KeyboardKey}"
                                        Command="{Binding KeyCommand}"
                                        CommandParameter=" "
                                        Content="SPACE"
                                        Width="90" />
                                <Button Style="{StaticResource KeyboardKey}"
                                        Command="{Binding BackspaceCommand}"
                                        Width="56">
                                    <iconPacks:PackIconMaterial Kind="BackspaceOutline"
                                                                Width="16"
                                                                Height="16" />
                                </Button>
                            </StackPanel>
                            <!-- Row 4: digits + decimal (for price field) -->
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center">
                                <Button Style="{StaticResource KeyboardKey}"
                                        Command="{Binding KeyCommand}"
                                        CommandParameter="1" />
                                <Button Style="{StaticResource KeyboardKey}"
                                        Command="{Binding KeyCommand}"
                                        CommandParameter="2" />
                                <Button Style="{StaticResource KeyboardKey}"
                                        Command="{Binding KeyCommand}"
                                        CommandParameter="3" />
                                <Button Style="{StaticResource KeyboardKey}"
                                        Command="{Binding KeyCommand}"
                                        CommandParameter="4" />
                                <Button Style="{StaticResource KeyboardKey}"
                                        Command="{Binding KeyCommand}"
                                        CommandParameter="5" />
                                <Button Style="{StaticResource KeyboardKey}"
                                        Command="{Binding KeyCommand}"
                                        CommandParameter="6" />
                                <Button Style="{StaticResource KeyboardKey}"
                                        Command="{Binding KeyCommand}"
                                        CommandParameter="7" />
                                <Button Style="{StaticResource KeyboardKey}"
                                        Command="{Binding KeyCommand}"
                                        CommandParameter="8" />
                                <Button Style="{StaticResource KeyboardKey}"
                                        Command="{Binding KeyCommand}"
                                        CommandParameter="9" />
                                <Button Style="{StaticResource KeyboardKey}"
                                        Command="{Binding KeyCommand}"
                                        CommandParameter="0" />
                                <Button Style="{StaticResource KeyboardKey}"
                                        Command="{Binding KeyCommand}"
                                        CommandParameter="."
                                        Content="."
                                        Width="44" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ── Save / Cancel ── -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Height="56"
                                FontSize="16"
                                FontWeight="Bold"
                                Background="#F1F5F9"
                                Foreground="{StaticResource TextDark}"
                                BorderThickness="0"
                                Command="{Binding CancelCommand}">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius"
                                            Value="12" />
                                </Style>
                            </Button.Resources>
                            <TextBlock Text="Cancel" />
                        </Button>
                        <Button Grid.Column="2"
                                Height="56"
                                FontSize="16"
                                FontWeight="Bold"
                                Background="{StaticResource SuccessGreen}"
                                Foreground="White"
                                BorderThickness="0"
                                Command="{Binding SaveCommand}">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius"
                                            Value="12" />
                                </Style>
                            </Button.Resources>
                            <TextBlock Text="Save &amp; Add" />
                        </Button>
                    </Grid>

                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>