<UserControl x:Class="RestaurantPOS.UI.Views.Login.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d"
             d:DesignHeight="900"
             d:DesignWidth="1000">

    <Grid Background="{StaticResource BackgroundGray}">
        <Grid Margin="40"
              MaxWidth="1200">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Background="{StaticResource SurfaceDark}"
                    CornerRadius="24"
                    Padding="40"
                    Margin="0,0,30,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20"
                                      ShadowDepth="0"
                                      Opacity="0.3" />
                </Border.Effect>

                <DockPanel>
                    <StackPanel DockPanel.Dock="Top"
                                Margin="0,0,0,30">
                        <TextBlock Text="Restaurant POS by EPS Tech"
                                   Foreground="{StaticResource PrimaryAccent}"
                                   FontSize="14"
                                   FontWeight="Black"
                                   Padding="2" />
                        <TextBlock Text="Select Your Profile"
                                   FontSize="32"
                                   FontWeight="Black"
                                   Foreground="White" />
                    </StackPanel>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Users}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ToggleButton x:Name="UserButton"
                                                  Height="140"
                                                  Margin="10"
                                                  Command="{Binding DataContext.SelectUserCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                  CommandParameter="{Binding Username}"
                                                  Style="{StaticResource PaymentMethodStyle}">
                                        <StackPanel VerticalAlignment="Center">
                                            <Border Width="60"
                                                    Height="60"
                                                    CornerRadius="30"
                                                    Background="#374151"
                                                    Margin="0,0,0,12">
                                                <iconPacks:PackIconMaterial Kind="Account"
                                                                            Foreground="White"
                                                                            Width="30"
                                                                            Height="30"
                                                                            HorizontalAlignment="Center"
                                                                            VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock Text="{Binding Username}"
                                                       FontSize="16"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </ToggleButton>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Border Grid.Column="1"
                    Background="{StaticResource SurfaceWhite}"
                    CornerRadius="24"
                    Padding="40">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15"
                                      ShadowDepth="0"
                                      Opacity="0.05" />
                </Border.Effect>

                <Grid VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <iconPacks:PackIconMaterial Kind="Lock"
                                                Foreground="{StaticResource PrimaryAccent}"
                                                HorizontalAlignment="Center"
                                                Margin="0,0,0,10" />

                    <TextBlock Grid.Row="1"
                               Text="SECURE LOGIN"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextMuted}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,4" />

                    <TextBlock Grid.Row="2"
                               Text="{Binding SelectedUser.Username, FallbackValue='Select a User'}"
                               FontSize="24"
                               FontWeight="Black"
                               Foreground="{StaticResource TextDark}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,30" />

                    <Border Grid.Row="3"
                            Background="#F8FAFC"
                            CornerRadius="12"
                            Padding="20"
                            Margin="5"
                            BorderBrush="{StaticResource BorderGray}"
                            BorderThickness="1">
                        <TextBlock Text="{Binding PinDisplay}"
                                   FontSize="30"
                                   FontWeight="Black"
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource PrimaryAccent}"/>
                    </Border>

                    <StackPanel Grid.Row="4">
                        <UniformGrid Columns="3"
                                     Rows="4"
                                     Height="350">
                            <Button Content="1"
                                    Style="{StaticResource KeypadButton}"
                                    Command="{Binding AppendDigitCommand}"
                                    CommandParameter="1" />
                            <Button Content="2"
                                    Style="{StaticResource KeypadButton}"
                                    Command="{Binding AppendDigitCommand}"
                                    CommandParameter="2" />
                            <Button Content="3"
                                    Style="{StaticResource KeypadButton}"
                                    Command="{Binding AppendDigitCommand}"
                                    CommandParameter="3" />
                            <Button Content="4"
                                    Style="{StaticResource KeypadButton}"
                                    Command="{Binding AppendDigitCommand}"
                                    CommandParameter="4" />
                            <Button Content="5"
                                    Style="{StaticResource KeypadButton}"
                                    Command="{Binding AppendDigitCommand}"
                                    CommandParameter="5" />
                            <Button Content="6"
                                    Style="{StaticResource KeypadButton}"
                                    Command="{Binding AppendDigitCommand}"
                                    CommandParameter="6" />
                            <Button Content="7"
                                    Style="{StaticResource KeypadButton}"
                                    Command="{Binding AppendDigitCommand}"
                                    CommandParameter="7" />
                            <Button Content="8"
                                    Style="{StaticResource KeypadButton}"
                                    Command="{Binding AppendDigitCommand}"
                                    CommandParameter="8" />
                            <Button Content="9"
                                    Style="{StaticResource KeypadButton}"
                                    Command="{Binding AppendDigitCommand}"
                                    CommandParameter="9" />
                            <Button Content="C"
                                    Style="{StaticResource KeypadActionButton}"
                                    Command="{Binding ClearPinCommand}" />
                            <Button Content="0"
                                    Style="{StaticResource KeypadButton}"
                                    Command="{Binding AppendDigitCommand}"
                                    CommandParameter="0" />
                            <Button Content="←"
                                    Style="{StaticResource KeypadActionButton}"
                                    Command="{Binding BackspaceCommand}" />
                        </UniformGrid>

                        <Button Content="UNLOCKED SYSTEM"
                                Height="60"
                                Margin="0,20,0,0"
                                Background="{StaticResource SuccessGreen}"
                                Foreground="White"
                                FontWeight="Black"
                                FontSize="16"
                                Command="{Binding ConfirmPinCommand}">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius"
                                            Value="12" />
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>