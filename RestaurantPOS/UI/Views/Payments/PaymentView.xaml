<UserControl x:Class="RestaurantPOS.UI.Views.Payments.PaymentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:RestaurantPOS.UI.Views.Payments"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900">
    <Grid Background="#F3F4F6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- TOP BAR -->
        <Border Background="#1F2937"
                Height="64"
                Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding TableLabel}"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="SemiBold" />

                <Button Grid.Column="1"
                        Style="{StaticResource TopBarButton}"
                        Content="Back"
                        Command="{Binding CancelCommand}"
                        Padding="16,6" />
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1"
              Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <!-- LEFT: SUMMARY -->
            <Border Background="White"
                    CornerRadius="12"
                    Padding="20"
                    Margin="0,0,20,0">

                <DockPanel LastChildFill="True">

                    <!-- HEADER -->
                    <TextBlock DockPanel.Dock="Top"
                               Text="Payment Summary"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="10,16" />

                    <!-- ✅ COVERS -->
                    <Border DockPanel.Dock="Top"
                            Background="#EEF2FF"
                            CornerRadius="8"
                            Padding="10"
                            Margin="10,0,10,12">

                        <StackPanel>
                            <TextBlock Text="Covers"
                                       FontWeight="Bold"
                                       FontSize="14" />

                            <TextBlock Text="{Binding CoversDisplay}"
                                       FontSize="13" />
                        </StackPanel>
                    </Border>

                    <!-- ✅ ITEMS LIST -->
                    <ListView ItemsSource="{Binding _orderState.Order.Items}"
                              Margin="10,0,10,12"
                              BorderThickness="0">

                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Name -->
                                    <TextBlock Text="{Binding ProductName}"
                                               FontWeight="SemiBold" />

                                    <!-- Qty -->
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Quantity}"
                                               Margin="12,0" />

                                    <!-- Line Total -->
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding LineTotal, StringFormat=£{0:F2}}"
                                               FontWeight="SemiBold" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>

                    </ListView>

                    <!-- ✅ TOTALS -->
                    <StackPanel DockPanel.Dock="Bottom"
                                Margin="10">

                        <Separator Margin="0,8" />

                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Total"
                                       FontWeight="Bold" />

                            <TextBlock Grid.Column="1"
                                       Text="{Binding Total, StringFormat=£{0:F2}}"
                                       FontWeight="Bold" />
                        </Grid>

                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Paid" />

                            <TextBlock Grid.Column="1"
                                       Text="{Binding PreviewPaid, StringFormat=£{0:F2}}" />
                        </Grid>

                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Due"
                                       FontWeight="Bold" />

                            <TextBlock Grid.Column="1"
                                       Text="{Binding PreviewDue, StringFormat=£{0:F2}}"
                                       FontWeight="Bold"
                                       Foreground="#DC2626" />
                        </Grid>

                    </StackPanel>

                </DockPanel>
            </Border>

            <!-- RIGHT: PAYMENT INPUT -->
            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="12"
                    Padding="20">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- METHOD -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,16">
                        <Button Content="Cash"
                                Width="120"
                                Margin="6"
                                Command="{Binding SelectCashCommand}">
                            <Button.Style>
                                <Style TargetType="Button"
                                       BasedOn="{StaticResource PosTileButton}">
                                    <Setter Property="Background"
                                            Value="#D1D5DB" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedMethod}"
                                                     Value="Cash">
                                            <Setter Property="Background"
                                                    Value="#16A34A" />
                                            <Setter Property="Foreground"
                                                    Value="White" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="Card"
                                Width="120"
                                Margin="6"
                                Command="{Binding SelectCardCommand}">
                            <Button.Style>
                                <Style TargetType="Button"
                                       BasedOn="{StaticResource PosTileButton}">
                                    <Setter Property="Background"
                                            Value="#D1D5DB" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedMethod}"
                                                     Value="Card">
                                            <Setter Property="Background"
                                                    Value="#16A34A" />
                                            <Setter Property="Foreground"
                                                    Value="White" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <!-- ENTERED AMOUNT -->
                    <TextBox Grid.Row="1"
                             Text="{Binding EnteredAmount, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="28"
                             HorizontalContentAlignment="Right"
                             Padding="12"
                             Margin="0,0,0,16" />

                    <!-- KEYPAD -->
                    <UniformGrid Grid.Row="2"
                                 Columns="3"
                                 Rows="4"
                                 Margin="0,0,0,16">
                        <Button Content="1"
                                Command="{Binding AppendDigitCommand}"
                                CommandParameter="1" />
                        <Button Content="2"
                                Command="{Binding AppendDigitCommand}"
                                CommandParameter="2" />
                        <Button Content="3"
                                Command="{Binding AppendDigitCommand}"
                                CommandParameter="3" />

                        <Button Content="4"
                                Command="{Binding AppendDigitCommand}"
                                CommandParameter="4" />
                        <Button Content="5"
                                Command="{Binding AppendDigitCommand}"
                                CommandParameter="5" />
                        <Button Content="6"
                                Command="{Binding AppendDigitCommand}"
                                CommandParameter="6" />

                        <Button Content="7"
                                Command="{Binding AppendDigitCommand}"
                                CommandParameter="7" />
                        <Button Content="8"
                                Command="{Binding AppendDigitCommand}"
                                CommandParameter="8" />
                        <Button Content="9"
                                Command="{Binding AppendDigitCommand}"
                                CommandParameter="9" />

                        <Button Content="C"
                                Command="{Binding ClearAmountCommand}" />
                        <Button Content="0"
                                Command="{Binding AppendDigitCommand}"
                                CommandParameter="0" />
                        <Button Content="←"
                                Command="{Binding BackspaceCommand}" />
                    </UniformGrid>

                    <!-- CONFIRM -->
                    <Button Grid.Row="3"
                            Content="Confirm Payment"
                            Height="56"
                            FontSize="18"
                            Background="#16A34A"
                            Foreground="White"
                            Command="{Binding PayCommand}" />
                </Grid>

            </Border>
        </Grid>
    </Grid>
</UserControl>
