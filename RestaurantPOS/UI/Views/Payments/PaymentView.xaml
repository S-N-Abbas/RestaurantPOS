<UserControl x:Class="RestaurantPOS.UI.Views.Payments.PaymentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:RestaurantPOS.UI.Views.Payments"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1300">
    <Grid Background="{StaticResource BackgroundGray}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        

        <Grid Grid.Row="1"
              Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Margin="0,0,24,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Background="{StaticResource SurfaceWhite}"
                        CornerRadius="16"
                        Padding="0"
                        BorderBrush="{StaticResource BorderGray}"
                        BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15"
                                          ShadowDepth="0"
                                          Opacity="0.05" />
                    </Border.Effect>

                    <DockPanel LastChildFill="True">
                        <TextBlock DockPanel.Dock="Top"
                                   Text="Payment Summary"
                                   FontSize="18"
                                   FontWeight="Black"
                                   Margin="24,24,24,16"
                                   Foreground="{StaticResource TextDark}" />

                        <Border DockPanel.Dock="Bottom"
                                Background="#F8FAFC"
                                Padding="24"
                                CornerRadius="0,0,16,16"
                                BorderBrush="{StaticResource BorderGray}"
                                BorderThickness="0,1,0,0">
                            <StackPanel>
                                <Grid Margin="0,0,0,4">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Account"
                                                                    Width="12"
                                                                    Height="12"
                                                                    Foreground="{StaticResource TextMuted}"
                                                                    VerticalAlignment="Center"
                                                                    Margin="0,0,8,0" />
                                        <TextBlock Text="Adult Covers"
                                                   Foreground="{StaticResource TextMuted}" />
                                        <TextBlock Text="{Binding AdultCount, StringFormat=' (x{0})'}"
                                                   Foreground="{StaticResource TextMuted}"
                                                   FontSize="11" />
                                    </StackPanel>
                                    <TextBlock HorizontalAlignment="Right"
                                               Foreground="{StaticResource TextDark}">
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource CurrencyFormatConverter}"
                                                          Mode="OneWay">
                                                <Binding Path="AdultCoverTotal" />
                                                <Binding Path="CurrencySymbol"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Grid>

                                <Grid Margin="0,0,0,12">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="AccountChild"
                                                                    Width="12"
                                                                    Height="12"
                                                                    Foreground="{StaticResource TextMuted}"
                                                                    VerticalAlignment="Center"
                                                                    Margin="0,0,8,0" />
                                        <TextBlock Text="Child Covers"
                                                   Foreground="{StaticResource TextMuted}" />
                                        <TextBlock Text="{Binding ChildCount, StringFormat=' (x{0})'}"
                                                   Foreground="{StaticResource TextMuted}"
                                                   FontSize="11" />
                                    </StackPanel>
                                    <TextBlock HorizontalAlignment="Right"
                                               Foreground="{StaticResource TextDark}">
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource CurrencyFormatConverter}"
                                                          Mode="OneWay">
                                                <Binding Path="ChildCoverTotal" />
                                                <Binding Path="CurrencySymbol"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Grid>

                                <Separator Background="{StaticResource BorderGray}"
                                           Margin="0,4,0,12" />

                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="Subtotal"
                                               Foreground="{StaticResource TextMuted}" />
                                    <TextBlock HorizontalAlignment="Right"
                                               Foreground="{StaticResource TextDark}">
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource CurrencyFormatConverter}"
                                                          Mode="OneWay">
                                                <Binding Path="Total" />
                                                <Binding Path="CurrencySymbol" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Grid>

                                <Grid Margin="0,0,0,12">
                                    <TextBlock Text="Paid to date"
                                               Foreground="{StaticResource TextMuted}" />
                                    <TextBlock HorizontalAlignment="Right"
                                               Foreground="{StaticResource SuccessGreen}"
                                               FontWeight="Bold">
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource CurrencyFormatConverter}"
                                                          Mode="OneWay">
                                                <Binding Path="AlreadyPaid" />
                                                <Binding Path="CurrencySymbol"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Grid>

                                <Separator Background="{StaticResource BorderGray}"
                                           Margin="0,4,0,12" />

                                <Grid>
                                    <TextBlock Text="AMOUNT DUE"
                                               FontSize="16"
                                               FontWeight="Black"
                                               Foreground="{StaticResource TextDark}" />
                                    <TextBlock FontSize="22"
                                               FontWeight="Black"
                                               Foreground="{StaticResource DangerRed}"
                                               HorizontalAlignment="Right">
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource CurrencyFormatConverter}"
                                                          Mode="OneWay">
                                                <Binding Path="Due" />
                                                <Binding Path="CurrencySymbol"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Grid>
                                <Separator Background="{StaticResource BorderGray}"
                                           Margin="0,4,0,12" />
                                
                                <!-- ✅ CHANGE DUE — only visible when customer overpays with cash -->
                                <Border CornerRadius="12"
                                        Padding="16,14"
                                        Margin="0,0,0,16"
                                        Visibility="{Binding HasChange,
                     Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background"
                                                    Value="#D1FAE5" />
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <iconPacks:PackIconMaterial Kind="CashRefund"
                                                                        Width="20"
                                                                        Height="20"
                                                                        Foreground="#065F46"
                                                                        VerticalAlignment="Center"
                                                                        Margin="0,0,10,0" />
                                            <TextBlock Text="CHANGE DUE"
                                                       FontSize="15"
                                                       FontWeight="Bold"
                                                       Foreground="#065F46"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                        <TextBlock HorizontalAlignment="Right"
                                                   FontSize="28"
                                                   FontWeight="Black"
                                                   Foreground="#065F46"
                                                   VerticalAlignment="Center">
            <Run Text="{Binding CurrencySymbol, Mode=OneWay}" />
            <Run Text="{Binding Change, StringFormat={}{0:N2}, Mode=OneWay}" />
                                        </TextBlock>
                                    </Grid>
                                </Border>

                            </StackPanel>
                        </Border>

                        <ListView ItemsSource="{Binding _orderState.Order.Items}"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  Margin="12,0"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="12,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="80" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{Binding ProductName}"
                                                   Foreground="{StaticResource TextDark}"
                                                   FontWeight="Medium"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Quantity, StringFormat='x{0}'}"
                                                   Foreground="{StaticResource TextMuted}"
                                                   Margin="15,0" />
                                        <TextBlock Grid.Column="2"
                                                   Foreground="{StaticResource TextDark}"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Right">
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource CurrencyFormatConverter}"
                                                              Mode="OneWay">
                                                    <Binding Path="LineTotal" />
                                                    <Binding Path="DataContext.CurrencySymbol"
                                                             RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </DockPanel>
                </Border>

                <Button Grid.Row="1"
                        Margin="0,16,0,0"
                        Height="50"
                        Style="{StaticResource KeypadActionButton}"
                        Command="{Binding PrintReceiptCommand}">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Printer"
                                                    Width="16"
                                                    Margin="0,0,10,0" />
                        <TextBlock Text="PRINT INTERIM BILL"
                                   FontWeight="Bold" />
                    </StackPanel>
                </Button>
            </Grid>

            <Border Grid.Column="1"
                    Background="{StaticResource SurfaceWhite}"
                    CornerRadius="16"
                    Padding="32">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15"
                                      ShadowDepth="0"
                                      Opacity="0.05" />
                </Border.Effect>

                <Grid Width="500"
                      HorizontalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <UniformGrid Columns="2"
                                 Margin="0,0,0,24">
                        <ToggleButton Content="CASH"
                                      Height="60"
                                      Margin="0,0,8,0"
                                      Style="{StaticResource PaymentMethodStyle}"
                                      IsChecked="{Binding SelectedMethod, Converter={StaticResource StringToBoolConverter}, ConverterParameter=Cash}" />

                        <ToggleButton Content="CARD"
                                      Height="60"
                                      Margin="8,0,0,0"
                                      Style="{StaticResource PaymentMethodStyle}"
                                      IsChecked="{Binding SelectedMethod, Converter={StaticResource StringToBoolConverter}, ConverterParameter=Card}" />
                    </UniformGrid>

                    <Border Grid.Row="1"
                            Background="#F8FAFC"
                            BorderBrush="{StaticResource PrimaryAccent}"
                            BorderThickness="2"
                            CornerRadius="12"
                            Padding="16"
                            Margin="0,0,0,24">
                        <Grid>
                            <TextBlock Text="{Binding CurrencySymbol}"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource PrimaryAccent}" />
                            <TextBlock Text="{Binding EnteredAmount}"
                                       FontSize="42"
                                       FontWeight="Black"
                                       HorizontalAlignment="Right"
                                       Foreground="{StaticResource TextDark}" />
                        </Grid>
                    </Border>

                    <UniformGrid Grid.Row="2"
                                 Columns="3"
                                 Rows="4">
                        <Button Content="1"
                                Style="{StaticResource KeypadButton}"
                                Command="{Binding AppendDigitCommand}"
                                CommandParameter="1" />
                        <Button Content="2"
                                Style="{StaticResource KeypadButton}"
                                Command="{Binding AppendDigitCommand}"
                                CommandParameter="2" />
                        <Button Content="3"
                                Style="{StaticResource KeypadButton}"
                                Command="{Binding AppendDigitCommand}"
                                CommandParameter="3" />
                        <Button Content="4"
                                Style="{StaticResource KeypadButton}"
                                Command="{Binding AppendDigitCommand}"
                                CommandParameter="4" />
                        <Button Content="5"
                                Style="{StaticResource KeypadButton}"
                                Command="{Binding AppendDigitCommand}"
                                CommandParameter="5" />
                        <Button Content="6"
                                Style="{StaticResource KeypadButton}"
                                Command="{Binding AppendDigitCommand}"
                                CommandParameter="6" />
                        <Button Content="7"
                                Style="{StaticResource KeypadButton}"
                                Command="{Binding AppendDigitCommand}"
                                CommandParameter="7" />
                        <Button Content="8"
                                Style="{StaticResource KeypadButton}"
                                Command="{Binding AppendDigitCommand}"
                                CommandParameter="8" />
                        <Button Content="9"
                                Style="{StaticResource KeypadButton}"
                                Command="{Binding AppendDigitCommand}"
                                CommandParameter="9" />
                        <Button Content="C"
                                Style="{StaticResource KeypadActionButton}"
                                Command="{Binding ClearAmountCommand}" />
                        <Button Content="0"
                                Style="{StaticResource KeypadButton}"
                                Command="{Binding AppendDigitCommand}"
                                CommandParameter="0" />
                        <Button Content="←"
                                Style="{StaticResource KeypadActionButton}"
                                Command="{Binding BackspaceCommand}" />
                    </UniformGrid>

                    <Button Grid.Row="3"
                            Command="{Binding PayCommand}"
                            Height="70"
                            Margin="0,24,0,0"
                            Background="{StaticResource SuccessGreen}"
                            Foreground="White"
                            BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius"
                                        Value="15" />
                            </Style>
                        </Button.Resources>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="CheckCircle"
                                                        Width="20"
                                                        Height="20"
                                                        Margin="0,0,12,0"
                                                        VerticalAlignment="Center" />
                            <TextBlock VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       FontSize="18"
                                       FontWeight="Black">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text"
                                                Value="CONFIRM PAYMENT" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasChange}"
                                                         Value="True">
                                                <Setter Property="Text"
                                                        Value="TAKE PAYMENT &amp; GIVE CHANGE" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
