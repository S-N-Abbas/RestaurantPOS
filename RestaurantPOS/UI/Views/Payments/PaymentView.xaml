<UserControl x:Class="RestaurantPOS.UI.Views.Payments.PaymentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:RestaurantPOS.UI.Views.Payments"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900">
    <Grid Background="#F3F4F6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- TOP BAR -->
        <Border Background="#1F2937"
                Height="64"
                Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding TableLabel}"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="SemiBold" />

                <Button Grid.Column="1"
                        Content="Back"
                        Command="{Binding CancelCommand}"
                        Padding="16,6" />
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1"
              Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <!-- LEFT: SUMMARY -->
            <Border Background="White"
                    CornerRadius="12"
                    Padding="20"
                    Margin="0,0,20,0">
                <StackPanel>

                    <TextBlock Text="Payment Summary"
                               FontSize="20"
                               FontWeight="Bold" 
                               Margin="10,16,10,16"/>

                    <Grid Margin="10, 0, 10, 0">
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Total" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Total, StringFormat=£{0:F2}}"
                                   FontWeight="Bold" />

                        <TextBlock Grid.Row="1"
                                   Text="Paid" />
                        <TextBlock Grid.Row="1"
                                   Grid.Column="1"
                                   Text="{Binding Paid, StringFormat=£{0:F2}}" />

                        <TextBlock Grid.Row="2"
                                   Text="Due"
                                   FontWeight="Bold" />
                        <TextBlock Grid.Row="2"
                                   Grid.Column="1"
                                   Text="{Binding Due, StringFormat=£{0:F2}}"
                                   FontWeight="Bold"
                                   Foreground="#DC2626" />
                    </Grid>

                </StackPanel>
            </Border>

            <!-- RIGHT: PAYMENT INPUT -->
            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="12"
                    Padding="20">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- METHOD -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,16">
                        <Button Content="Cash"
                                Width="120"
                                Margin="6"
                                Command="{Binding SelectCashCommand}"
                                Style="{StaticResource PosTileButton}" />

                        <Button Content="Card"
                                Width="120"
                                Margin="6"
                                Command="{Binding SelectCardCommand}"
                                Style="{StaticResource PosTileButton}" />

                        <Button Content="Split"
                                Width="120"
                                Margin="6"
                                Command="{Binding SplitBillCommand}"
                                Style="{StaticResource PosTileButton}" />
                    </StackPanel>

                    <!-- ENTERED AMOUNT -->
                    <TextBox Grid.Row="1"
                             Text="{Binding EnteredAmount, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="28"
                             HorizontalContentAlignment="Right"
                             Padding="12"
                             Margin="0,0,0,16" />

                    <!-- KEYPAD -->
                    <UniformGrid Grid.Row="2"
                                 Columns="3"
                                 Rows="4"
                                 Margin="0,0,0,16">
                        <Button Content="1"
                                Command="{Binding AppendDigitCommand}"
                                CommandParameter="1" />
                        <Button Content="2"
                                Command="{Binding AppendDigitCommand}"
                                CommandParameter="2" />
                        <Button Content="3"
                                Command="{Binding AppendDigitCommand}"
                                CommandParameter="3" />

                        <Button Content="4"
                                Command="{Binding AppendDigitCommand}"
                                CommandParameter="4" />
                        <Button Content="5"
                                Command="{Binding AppendDigitCommand}"
                                CommandParameter="5" />
                        <Button Content="6"
                                Command="{Binding AppendDigitCommand}"
                                CommandParameter="6" />

                        <Button Content="7"
                                Command="{Binding AppendDigitCommand}"
                                CommandParameter="7" />
                        <Button Content="8"
                                Command="{Binding AppendDigitCommand}"
                                CommandParameter="8" />
                        <Button Content="9"
                                Command="{Binding AppendDigitCommand}"
                                CommandParameter="9" />

                        <Button Content="C"
                                Command="{Binding ClearAmountCommand}" />
                        <Button Content="0"
                                Command="{Binding AppendDigitCommand}"
                                CommandParameter="0" />
                        <Button Content="←"
                                Command="{Binding BackspaceCommand}" />
                    </UniformGrid>

                    <!-- CONFIRM -->
                    <Button Grid.Row="3"
                            Content="Confirm Payment"
                            Height="56"
                            FontSize="18"
                            Background="#16A34A"
                            Foreground="White"
                            Command="{Binding PayCommand}"
                            IsEnabled="{Binding CanPay}" />
                </Grid>

            </Border>
        </Grid>
    </Grid>
</UserControl>
