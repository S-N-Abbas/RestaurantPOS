<UserControl x:Class="RestaurantPOS.UI.Views.ZReport.ZReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="768"
             d:DesignWidth="1200">

    <Grid Background="{StaticResource BackgroundGray}">
        <DockPanel>

            <!-- ── HEADER ── -->
            <Border DockPanel.Dock="Top"
                    Height="80"
                    Background="White"
                    BorderBrush="{StaticResource BorderGray}"
                    BorderThickness="0,0,0,1"
                    Padding="28,0">
                <Grid VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <iconPacks:PackIconMaterial Kind="FileChartOutline"
                                                    Foreground="{StaticResource PrimaryAccent}"
                                                    Width="24"
                                                    Height="24"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,14,0" />
                        <TextBlock Text="Z-REPORT"
                                   FontSize="22"
                                   FontWeight="Black"
                                   Foreground="{StaticResource TextDark}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Print button -->
                    <Button HorizontalAlignment="Right"
                            Height="44"
                            Padding="20,0"
                            FontSize="14"
                            FontWeight="Bold"
                            Background="{StaticResource PrimaryAccent}"
                            Foreground="White"
                            BorderThickness="0"
                            Command="{Binding PrintCommand}"
                            Visibility="{Binding HasReport,
                                         Converter={StaticResource BoolToVisibilityConverter}}">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius"
                                        Value="10" />
                            </Style>
                        </Button.Resources>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Printer"
                                                        Width="14"
                                                        Height="14"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,8,0" />
                            <TextBlock Text="Print Report"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- ── LEFT PANEL: Controls ── -->
            <Border DockPanel.Dock="Left"
                    Width="280"
                    Background="White"
                    BorderBrush="{StaticResource BorderGray}"
                    BorderThickness="0,0,1,0"
                    Padding="20">
                <StackPanel>

                    <!-- Date range label -->
                    <TextBlock Text="DATE RANGE"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextMuted}"
                               Margin="0,0,0,12" />

                    <!-- Quick range buttons -->
                    <UniformGrid Rows="2"
                                 Columns="2"
                                 Margin="0,0,0,20">
                        <Button Height="40"
                                Margin="0,0,4,4"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Background="#F1F5F9"
                                BorderThickness="0"
                                Command="{Binding SetTodayCommand}">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius"
                                            Value="8" />
                                </Style>
                            </Button.Resources>
                            <TextBlock Text="Today" />
                        </Button>
                        <Button Height="40"
                                Margin="4,0,0,4"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Background="#F1F5F9"
                                BorderThickness="0"
                                Command="{Binding SetYesterdayCommand}">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius"
                                            Value="8" />
                                </Style>
                            </Button.Resources>
                            <TextBlock Text="Yesterday" />
                        </Button>
                        <Button Height="40"
                                Margin="0,0,4,0"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Background="#F1F5F9"
                                BorderThickness="0"
                                Command="{Binding SetThisWeekCommand}">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius"
                                            Value="8" />
                                </Style>
                            </Button.Resources>
                            <TextBlock Text="This Week" />
                        </Button>
                        <Button Height="40"
                                Margin="4,0,0,0"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Background="#F1F5F9"
                                BorderThickness="0"
                                Command="{Binding SetThisMonthCommand}">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius"
                                            Value="8" />
                                </Style>
                            </Button.Resources>
                            <TextBlock Text="This Month" />
                        </Button>
                    </UniformGrid>

                    <!-- From date -->
                    <TextBlock Text="From"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextMuted}"
                               Margin="0,0,0,6" />
                    <DatePicker SelectedDate="{Binding From}"
                                Height="44"
                                Margin="0,0,0,16"
                                FontSize="14" />

                    <!-- To date -->
                    <TextBlock Text="To"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextMuted}"
                               Margin="0,0,0,6" />
                    <DatePicker SelectedDate="{Binding To}"
                                Height="44"
                                Margin="0,0,0,24"
                                FontSize="14" />

                    <!-- Generate button -->
                    <Button Height="52"
                            FontSize="15"
                            FontWeight="Bold"
                            Background="{StaticResource PrimaryAccent}"
                            Foreground="White"
                            BorderThickness="0"
                            Command="{Binding GenerateCommand}">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius"
                                        Value="12" />
                            </Style>
                        </Button.Resources>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="ChartBar"
                                                        Width="16"
                                                        Height="16"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,10,0" />
                            <TextBlock Text="Generate Report"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Summary tiles — shown after generation -->
                    <StackPanel Margin="0,24,0,0"
                                Visibility="{Binding HasReport,
                                             Converter={StaticResource BoolToVisibilityConverter}}">

                        <TextBlock Text="SUMMARY"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="0,0,0,12" />

                        <!-- Total Income tile -->
                        <Border Background="#EFF6FF"
                                CornerRadius="12"
                                Padding="16,12"
                                Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Total Income"
                                           FontSize="11"
                                           Foreground="{StaticResource TextMuted}" />
                                <TextBlock Text="{Binding TotalIncomeDisplay}"
                                           FontSize="22"
                                           FontWeight="Black"
                                           Foreground="{StaticResource PrimaryAccent}" />
                            </StackPanel>
                        </Border>

                        <!-- Cash / Card row -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Background="#F0FDF4"
                                    CornerRadius="12"
                                    Padding="12,10">
                                <StackPanel>
                                    <TextBlock Text="Cash"
                                               FontSize="10"
                                               Foreground="{StaticResource TextMuted}" />
                                    <TextBlock Text="{Binding CashIncomeDisplay}"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="#065F46" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    Background="#EFF6FF"
                                    CornerRadius="12"
                                    Padding="12,10">
                                <StackPanel>
                                    <TextBlock Text="Card"
                                               FontSize="10"
                                               Foreground="{StaticResource TextMuted}" />
                                    <TextBlock Text="{Binding CardIncomeDisplay}"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="#1E40AF" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Orders / Cancellations row -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Background="#F8FAFC"
                                    CornerRadius="12"
                                    Padding="12,10"
                                    BorderBrush="{StaticResource BorderGray}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Orders"
                                               FontSize="10"
                                               Foreground="{StaticResource TextMuted}" />
                                    <TextBlock Text="{Binding TotalOrdersDisplay}"
                                               FontSize="20"
                                               FontWeight="Black"
                                               Foreground="{StaticResource TextDark}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    Background="#FEF2F2"
                                    CornerRadius="12"
                                    Padding="12,10">
                                <StackPanel>
                                    <TextBlock Text="Cancelled"
                                               FontSize="10"
                                               Foreground="{StaticResource TextMuted}" />
                                    <TextBlock Text="{Binding CancellationsDisplay}"
                                               FontSize="20"
                                               FontWeight="Black"
                                               Foreground="#DC2626" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- ── RIGHT PANEL: Report preview ── -->
            <Grid>

                <!-- Loading -->
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Visibility="{Binding IsLoading,
                                         Converter={StaticResource BoolToVisibilityConverter}}">
                    <iconPacks:PackIconMaterial Kind="Loading"
                                                Width="40"
                                                Height="40"
                                                Foreground="{StaticResource TextMuted}"
                                                HorizontalAlignment="Center" />
                    <TextBlock Text="Generating report..."
                               FontSize="14"
                               Foreground="{StaticResource TextMuted}"
                               HorizontalAlignment="Center"
                               Margin="0,12,0,0" />
                </StackPanel>

                <!-- Empty state -->
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Visibility="{Binding HasReport,
                                         Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <iconPacks:PackIconMaterial Kind="FileChartOutline"
                                                Width="64"
                                                Height="64"
                                                Foreground="{StaticResource TextMuted}"
                                                HorizontalAlignment="Center"
                                                Opacity="0.3" />
                    <TextBlock Text="Select a date range and tap Generate"
                               FontSize="16"
                               Foreground="{StaticResource TextMuted}"
                               HorizontalAlignment="Center"
                               Margin="0,16,0,0" />
                </StackPanel>

                <!-- Report document viewer -->
                <FlowDocumentScrollViewer Document="{Binding Document}"
                                          Visibility="{Binding HasReport,
                                                       Converter={StaticResource BoolToVisibilityConverter}}"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Auto"
                                          Zoom="100"
                                          IsToolBarVisible="False"
                                          Background="{StaticResource BackgroundGray}"
                                          Padding="20" />
            </Grid>
        </DockPanel>
    </Grid>
</UserControl>