<UserControl x:Class="RestaurantPOS.UI.Views.Home.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:RestaurantPOS.UI.Views.Home"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="20">
        <UniformGrid Columns="3">

            <Button Content="ORDER"
                    Style="{StaticResource PosTileButton}"
                    Command="{Binding OrderCommand}" />

            <Button Content="REPORTS"
                    Style="{StaticResource PosTileButton}"
                    Command="{Binding ReportsCommand}" />

            <Button Content="BACK OFFICE"
                    Style="{StaticResource PosTileButton}"
                    Command="{Binding BackOfficeCommand}" />

        </UniformGrid>
    </Grid>
</UserControl>
