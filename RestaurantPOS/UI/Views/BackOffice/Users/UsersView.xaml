<UserControl x:Class="RestaurantPOS.UI.Views.BackOffice.Users.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:RestaurantPOS.UI.Views.BackOffice.Users"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1100">
    <Grid Background="#F3F4F6">

        <Border Background="White"
                CornerRadius="12"
                Padding="20"
                Margin="20">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <DockPanel Grid.Row="0"
                           Margin="0,0,0,16">

                    <TextBlock Text="Users Management"
                               FontSize="22"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               DockPanel.Dock="Left" />

                    <Button Content="+ New User"
                            Width="120"
                            Height="36"
                            FontWeight="SemiBold"
                            Background="#2563EB"
                            Foreground="White"
                            BorderThickness="0"
                            DockPanel.Dock="Right"
                            Command="{Binding NewUserCommand}" />
                </DockPanel>

                <!-- MAIN CONTENT -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- USERS GRID -->
                    <DataGrid Grid.Column="0"
                              ItemsSource="{Binding Users}"
                              SelectedItem="{Binding SelectedUser}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              RowHeight="40">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="Name"
                                                Binding="{Binding Username}"
                                                Width="*" />

                            <DataGridTextColumn Header="Role"
                                                Binding="{Binding Role}"
                                                Width="150" />

                            <DataGridCheckBoxColumn Header="Active"
                                                    Binding="{Binding IsActive}"
                                                    Width="100" />

                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- SPACER -->
                    <Grid Grid.Column="1" />

                    <!-- EDITOR PANEL -->
                    <Border Grid.Column="2"
                            Background="#F9FAFB"
                            CornerRadius="10"
                            Padding="16">

                        <StackPanel>

                            <TextBlock Text="User Details"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Margin="0,0,0,16" />

                            <!-- NAME -->
                            <TextBlock Text="Name" />
                            <TextBox Text="{Binding EditorName}"
                                     Margin="0,4,0,12"
                                     Height="32" />

                            <!-- ROLE -->
                            <TextBlock Text="Role" />
                            <ComboBox SelectedItem="{Binding EditorRole}"
                                      Margin="0,4,0,12"
                                      Height="32" 
                                      ItemsSource="{Binding Roles}"/>

                            <!-- PIN -->
                            <TextBlock Text="PIN" />
                            <PasswordBox Margin="0,4,0,12"
                                         Height="32"
                                         x:Name="PinBox"
                                         PasswordChanged="PinBox_PasswordChanged"/>

                            <!-- ACTIVE -->
                            <CheckBox Content="Active User"
                                      IsChecked="{Binding EditorIsActive}"
                                      Margin="0,8,0,16" />

                            <!-- ACTION BUTTONS -->
                            <StackPanel Orientation="Horizontal">

                                <Button Content="Save"
                                        Width="90"
                                        Height="36"
                                        Background="#16A34A"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Command="{Binding SaveUserCommand}" />

                                <Button Content="Clear"
                                        Width="90"
                                        Height="36"
                                        Margin="8,0,0,0"
                                        Command="{Binding ClearEditorCommand}" />

                                <Button Content="Delete"
                                        Width="90"
                                        Height="36"
                                        Margin="8,0,0,0"
                                        Background="#DC2626"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Command="{Binding DeleteUserCommand}" />

                            </StackPanel>

                        </StackPanel>
                    </Border>

                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
