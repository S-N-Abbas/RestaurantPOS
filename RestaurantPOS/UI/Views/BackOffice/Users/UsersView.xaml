<UserControl x:Class="RestaurantPOS.UI.Views.BackOffice.Users.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="1100">

    <Grid Background="{StaticResource BackgroundGray}">
        <Grid Margin="30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Background="{StaticResource SurfaceWhite}"
                    CornerRadius="16"
                    Margin="0,0,20,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15"
                                      ShadowDepth="0"
                                      Opacity="0.05" />
                </Border.Effect>

                <DockPanel Margin="25">
                    <DockPanel DockPanel.Dock="Top"
                               LastChildFill="False"
                               Margin="0,0,0,20">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="Staff Management"
                                       FontSize="24"
                                       FontWeight="Black"
                                       Foreground="{StaticResource TextDark}" />
                            <TextBlock Text="Manage system access and roles"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="13" />
                        </StackPanel>

                        <Button DockPanel.Dock="Right"
                                VerticalAlignment="Center"
                                Content="+ New User"
                                Command="{Binding NewUserCommand}"
                                Background="{StaticResource PrimaryAccent}"
                                Foreground="White"
                                Padding="20,10"
                                FontWeight="Bold">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius"
                                            Value="8" />
                                </Style>
                            </Button.Resources>
                        </Button>
                    </DockPanel>

                    <Border DockPanel.Dock="Top"
                            Background="#F8FAFC"
                            CornerRadius="8"
                            Padding="10,5"
                            Margin="0,0,0,15"
                            BorderBrush="{StaticResource BorderGray}"
                            BorderThickness="1">
                        <Grid>
                            <iconPacks:PackIconMaterial Kind="Magnify"
                                                        Foreground="{StaticResource TextMuted}"
                                                        VerticalAlignment="Center" />
                            <TextBox Margin="25,0,0,0"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     VerticalAlignment="Center"
                                     Tag="Search users..."
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </Border>

                    <DataGrid ItemsSource="{Binding Users}"
                              SelectedItem="{Binding SelectedUser}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              SelectionMode="Single"
                              RowHeight="50"
                              Background="Transparent"
                              BorderThickness="0">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background"
                                        Value="Transparent" />
                                <Setter Property="Foreground"
                                        Value="{StaticResource TextMuted}" />
                                <Setter Property="FontWeight"
                                        Value="SemiBold" />
                                <Setter Property="Padding"
                                        Value="10,0" />
                                <Setter Property="BorderThickness"
                                        Value="0,0,0,1" />
                                <Setter Property="BorderBrush"
                                        Value="{StaticResource BorderGray}" />
                            </Style>
                        </DataGrid.Resources>

                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="User"
                                                    Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <Border Width="32"
                                                    Height="32"
                                                    CornerRadius="16"
                                                    Background="#EFF6FF"
                                                    Margin="0,0,10,0">
                                                <iconPacks:PackIconMaterial Kind="Account"
                                                                            Foreground="{StaticResource PrimaryAccent}"
                                                                            Width="14"
                                                                            Height="14"
                                                                            HorizontalAlignment="Center"
                                                                            VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock Text="{Binding Username}"
                                                       VerticalAlignment="Center"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource TextDark}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Access Role"
                                                    Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Role}"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource TextDark}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Status"
                                                    Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="10"
                                                Padding="5"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Background="{Binding IsActive, Converter={StaticResource StatusToBrushConverter}}">
                                            <TextBlock Text="{Binding IsActive, Converter={StaticResource StatusToTextConverter}}"
                                                       FontSize="10"
                                                       FontWeight="Bold"
                                                       Foreground="White" />
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Border Grid.Column="1"
                    Background="{StaticResource SurfaceWhite}"
                    CornerRadius="16"
                    Padding="30">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15"
                                      ShadowDepth="0"
                                      Opacity="0.05" />
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Edit User Profile"
                               FontSize="20"
                               FontWeight="Black"
                               Margin="0,0,0,25" />

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="DISPLAY NAME"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextMuted}"
                                       Margin="0,0,0,8" />
                            <TextBox Text="{Binding EditorName}"
                                     Height="40"
                                     Margin="0,0,0,20" />

                            <TextBlock Text="SYSTEM ROLE"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextMuted}"
                                       Margin="0,0,0,8" />
                            <ComboBox ItemsSource="{Binding Roles}"
                                      SelectedItem="{Binding EditorRole, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                      Height="40"
                                      Margin="0,0,0,20" />

                            <TextBlock Text="SECURITY PIN"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextMuted}"
                                       Margin="0,0,0,8" />
                            <PasswordBox x:Name="PinBox"
                                         Height="40"
                                         Margin="0,0,0,10"
                                         PasswordChanged="PinBox_PasswordChanged" />
                            <TextBlock Text="Leave empty to keep current PIN"
                                       FontSize="11"
                                       Foreground="{StaticResource TextMuted}"
                                       Margin="0,0,0,20"
                                       FontStyle="Italic" />

                            <CheckBox Content="Enable account access"
                                      IsChecked="{Binding EditorIsActive}"
                                      FontWeight="SemiBold" />
                        </StackPanel>
                    </ScrollViewer>

                    <Grid Grid.Row="2"
                          Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button Content="Save User"
                                Command="{Binding SaveUserCommand}"
                                Background="{StaticResource SuccessGreen}"
                                Foreground="White"
                                Height="45"
                                Margin="0,0,5,0"
                                FontWeight="Bold">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius"
                                            Value="10" />
                                </Style>
                            </Button.Resources>
                        </Button>

                        <Button Grid.Column="1"
                                Content="Delete"
                                Command="{Binding DeleteUserCommand}"
                                Background="{StaticResource DangerRed}"
                                Foreground="White"
                                Height="45"
                                Margin="5,0,0,0"
                                FontWeight="Bold">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius"
                                            Value="10" />
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>