<UserControl x:Class="RestaurantPOS.UI.Views.BackOffice.BackOfficeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:RestaurantPOS.UI.Views.BackOffice"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid Margin="20">
        <UniformGrid Rows="2">
            <UniformGrid Columns="3">

                <Button Content="USERS"
                        Style="{StaticResource PosTileButton}"
                        Command="{Binding UserManagementCommand}" />

                <Button Content="CATEGORIES"
                        Style="{StaticResource PosTileButton}"
                        Command="{Binding CategoriesCommand}" />

                <Button Content="PRODUCTS"
                        Style="{StaticResource PosTileButton}"
                        Command="{Binding ProductsCommand}" />

            </UniformGrid>
            <UniformGrid Columns="3">

                <Button Content="TABLES"
                        Style="{StaticResource PosTileButton}"
                        Command="{Binding TablesCommand}" />

                <Button Content="COVERS"
                        Style="{StaticResource PosTileButton}"
                        Command="{Binding CoversCommand}" />

                <Button Content="SETTINGS"
                        Style="{StaticResource PosTileButton}"
                        Command="{Binding SettingsCommand}" />

            </UniformGrid>
        </UniformGrid>
        
    </Grid>
</UserControl>
