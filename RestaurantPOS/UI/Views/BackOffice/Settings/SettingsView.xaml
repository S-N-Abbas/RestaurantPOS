<UserControl x:Class="RestaurantPOS.UI.Views.BackOffice.Settings.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:RestaurantPOS.UI.Views.BackOffice.Settings"
             mc:Ignorable="d" 
             d:DesignHeight="750" d:DesignWidth="1000">
    <Grid Background="{StaticResource BackgroundGray}">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Margin="0,0,0,25">
                <TextBlock Text="System Settings"
                           FontSize="28"
                           FontWeight="Black"
                           Foreground="{StaticResource TextDark}" />
                <TextBlock Text="Configure business identity, tax rates, and terminal behavior."
                           Foreground="{StaticResource TextMuted}" />
            </StackPanel>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{StaticResource SurfaceWhite}"
                        CornerRadius="16,0,0,16"
                        Padding="10">
                    <StackPanel>
                        <RadioButton x:Name="BtnGeneral"
                                     Content="Business Identity"
                                     IsChecked="True"
                                     Style="{StaticResource MenuButtonStyle}" />
                        <RadioButton x:Name="BtnFinancial"
                                     Content="VAT &amp; Finance"
                                     Style="{StaticResource MenuButtonStyle}" />
                        <RadioButton x:Name="BtnOperational"
                                     Content="Operational"
                                     Style="{StaticResource MenuButtonStyle}" />
                        <RadioButton x:Name="BtnPrinting"
                                     Content="Printing"
                                     Style="{StaticResource MenuButtonStyle}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Background="{StaticResource SurfaceWhite}"
                        CornerRadius="0,16,16,0"
                        BorderBrush="{StaticResource BorderGray}"
                        BorderThickness="1,0,0,0">
                    <Grid Margin="40,20">

                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Visibility="{Binding IsChecked, ElementName=BtnGeneral, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel MaxWidth="700"
                                        Width="500"
                                        HorizontalAlignment="Left">
                                <TextBlock Text="Business Details"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Margin="0,0,0,10" />

                                <TextBlock Text="BUSINESS NAME"
                                           Style="{StaticResource FieldLabel}"
                                           Margin="0,0,0,5" />
                                <TextBox Text="{Binding EditableSettings.BusinessName, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Text="ADDRESS LINE 1"
                                           Style="{StaticResource FieldLabel}" />
                                <TextBox Text="{Binding EditableSettings.AddressLine1}" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,10,0">
                                        <TextBlock Text="CITY"
                                                   Style="{StaticResource FieldLabel}" />
                                        <TextBox Text="{Binding EditableSettings.City}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="POSTCODE"
                                                   Style="{StaticResource FieldLabel}" />
                                        <TextBox Text="{Binding EditableSettings.Postcode}" />
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="PHONE NUMBER"
                                           Style="{StaticResource FieldLabel}" />
                                <TextBox Text="{Binding EditableSettings.PhoneNo}" />
                            </StackPanel>
                        </ScrollViewer>

                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Visibility="{Binding IsChecked, ElementName=BtnFinancial, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel MaxWidth="500"
                                        HorizontalAlignment="Left">
                                <TextBlock Text="Tax &amp; Currency"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Margin="0,0,0,10" />

                                <TextBlock Text="VAT REGISTRATION NUMBER"
                                           Style="{StaticResource FieldLabel}"
                                           Margin="0,0,0,5" />
                                <TextBox Text="{Binding EditableSettings.VatNo}" />

                                <TextBlock Text="DEFAULT VAT RATE (%)"
                                           Style="{StaticResource FieldLabel}" />
                                <TextBox Text="{Binding EditableSettings.DefaultVatRate}" />

                                <TextBlock Text="CURRENCY SYMBOL"
                                           Style="{StaticResource FieldLabel}" />
                                <TextBox Text="{Binding EditableSettings.CurrencySymbol}"
                                         Width="100"
                                         HorizontalAlignment="Left" />
                            </StackPanel>
                        </ScrollViewer>

                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Visibility="{Binding IsChecked, ElementName=BtnOperational, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel MaxWidth="500"
                                        HorizontalAlignment="Left">
                                <TextBlock Text="Till Configuration"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Margin="0,0,0,10" />

                                <TextBlock Text="TILL NUMBER"
                                           Style="{StaticResource FieldLabel}"
                                           Margin="0,0,0,5" />
                                <TextBox Text="{Binding EditableSettings.TillNo}" />

                                <!-- ── Covers ── -->
                                <TextBlock Text="ADULT COVER LABEL"
                                           Style="{StaticResource FieldLabel}" />
                                <TextBox Text="{Binding EditableSettings.AdultCoverLabel, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Text="ADULT COVER PRICE"
                                           Style="{StaticResource FieldLabel}" />
                                <TextBox Text="{Binding EditableSettings.AdultCoverPrice}" />

                                <TextBlock Text="CHILD COVER LABEL"
                                           Style="{StaticResource FieldLabel}" />
                                <TextBox Text="{Binding EditableSettings.ChildCoverLabel, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Text="CHILD COVER PRICE"
                                           Style="{StaticResource FieldLabel}" />
                                <TextBox Text="{Binding EditableSettings.ChildCoverPrice}" />
                            </StackPanel>
                        </ScrollViewer>

                        <!-- ══════════════════════════════════════
                             PRINTING PANEL
                        ══════════════════════════════════════ -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Visibility="{Binding IsChecked, ElementName=BtnPrinting, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel MaxWidth="500"
                                        HorizontalAlignment="Left">
                                <TextBlock Text="Printing"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Margin="0,0,0,10" />

                                <!-- Print receipt toggle -->
                                <CheckBox Content="Automatically print receipt on payment"
                                          IsChecked="{Binding EditableSettings.PrintReceiptOnPayment, Mode=TwoWay}"
                                          FontWeight="SemiBold"
                                          Foreground="{StaticResource TextDark}"
                                          Margin="0,0,0,20" />

                                <!-- Default printer -->
                                <TextBlock Style="{StaticResource FieldLabel}">
                                    DEFAULT RECEIPT PRINTER
                                    <Run Foreground="{StaticResource TextMuted}"
                                         FontStyle="Italic"
                                         FontWeight="Normal">  — leave blank to show dialog each time</Run>
                                </TextBlock>

                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <ComboBox Grid.Column="0"
                                              ItemsSource="{Binding AvailablePrinters}"
                                              SelectedItem="{Binding EditableSettings.DefaultPrinter, Mode=TwoWay}"
                                              Margin="0,0,8,0">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock>
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="{Binding}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding}" Value="">
                                                                    <Setter Property="Text" Value="— Show print dialog each time —" />
                                                                    <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
                                                                    <Setter Property="FontStyle" Value="Italic" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>

                                    <Button Grid.Column="1"
                                            Command="{Binding RefreshPrintersCommand}"
                                            Height="30"
                                            Padding="12,0"
                                            Background="Transparent"
                                            BorderBrush="{StaticResource BorderGray}"
                                            BorderThickness="1"
                                            ToolTip="Refresh printer list">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="6" />
                                            </Style>
                                        </Button.Resources>
                                        <TextBlock Text="↻ Refresh"
                                                   Foreground="{StaticResource TextMuted}"
                                                   FontSize="12" />
                                    </Button>
                                </Grid>

                                <!-- Footer message -->
                                <TextBlock Text="RECEIPT FOOTER MESSAGE"
                                           Style="{StaticResource FieldLabel}" />
                                <TextBox Text="{Binding EditableSettings.FooterMessage, UpdateSourceTrigger=PropertyChanged}"
                                         MaxLength="120"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="False" />
                                <TextBlock Text="Printed at the bottom of every receipt."
                                           Foreground="{StaticResource TextMuted}"
                                           FontSize="11"
                                           FontStyle="Italic"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,20,0,0">
                <Button Content="Reset Changes"
                        Command="{Binding ResetCommand}"
                        Width="150"
                        Height="45"
                        Background="Transparent"
                        Foreground="{StaticResource TextMuted}"
                        BorderThickness="0" />
                <Button Content="Save All Settings"
                        Command="{Binding SaveCommand}"
                        Width="200"
                        Height="45"
                        Background="{StaticResource PrimaryAccent}"
                        Foreground="White"
                        FontWeight="Bold">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius"
                                    Value="10" />
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
