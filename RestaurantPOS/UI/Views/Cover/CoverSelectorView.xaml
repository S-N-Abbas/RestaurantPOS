<UserControl x:Class="RestaurantPOS.UI.Views.Cover.CoverSelectorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:RestaurantPOS.UI.Views.Cover"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1200">
    <Border Background="#CC1E293B">
        <Border Width="400"
                Background="White"
                CornerRadius="20"
                Padding="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30"
                                  ShadowDepth="0"
                                  Opacity="0.2" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Margin="0,0,0,24">
                    <TextBlock Text="Guest Covers"
                               FontSize="24"
                               FontWeight="Black"
                               Foreground="#1E293B" />
                    <TextBlock Text="Set the number of people at the table"
                               FontSize="13"
                               Foreground="#64748B" />
                </StackPanel>

                <StackPanel Grid.Row="1"
                            Margin="0,0,0,20">
                    <Border Background="#F8FAFC"
                            CornerRadius="12"
                            Padding="12"
                            Margin="0,0,0,8"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="Account"
                                                            VerticalAlignment="Center"
                                                            Foreground="#2563EB"
                                                            Width="18" />
                                <TextBlock Text="Adults"
                                           VerticalAlignment="Center"
                                           Margin="10,0,0,0"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#1E293B" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right">
                                <Button Style="{StaticResource CircleActionButton}"
                                        Content="−"
                                        Command="{Binding DecreaseAdultsCommand}" />
                                <TextBox Text="{Binding AdultCovers}"
                                         Width="50"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         FontSize="20"
                                         FontWeight="Bold"
                                         Foreground="#2563EB"
                                         GotFocus="AdultsBox_GotFocus"
                                         HorizontalContentAlignment="Center"
                                         VerticalAlignment="Center" />
                                <Button Style="{StaticResource CircleActionButton}"
                                        Content="+"
                                        Command="{Binding IncreaseAdultsCommand}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Background="#F8FAFC"
                            CornerRadius="12"
                            Padding="12"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="HumanChild"
                                                            VerticalAlignment="Center"
                                                            Foreground="#2563EB"
                                                            Width="18" />
                                <TextBlock Text="Children"
                                           VerticalAlignment="Center"
                                           Margin="10,0,0,0"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#1E293B" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right">
                                <Button Style="{StaticResource CircleActionButton}"
                                        Content="−"
                                        Command="{Binding DecreaseChildrenCommand}" />
                                <TextBox Text="{Binding ChildCovers}"
                                         Width="50"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         FontSize="20"
                                         FontWeight="Bold"
                                         Foreground="#2563EB"
                                         GotFocus="ChildrenBox_GotFocus"
                                         HorizontalContentAlignment="Center"
                                         VerticalAlignment="Center" />
                                <Button Style="{StaticResource CircleActionButton}"
                                        Content="+"
                                        Command="{Binding IncreaseChildrenCommand}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>

                <UniformGrid Grid.Row="2"
                             Columns="3"
                             Rows="4"
                             Height="280">
                    <Button Content="1"
                            Style="{StaticResource KeypadButton}"
                            Command="{Binding AppendDigitCommand}"
                            CommandParameter="1" />
                    <Button Content="2"
                            Style="{StaticResource KeypadButton}"
                            Command="{Binding AppendDigitCommand}"
                            CommandParameter="2" />
                    <Button Content="3"
                            Style="{StaticResource KeypadButton}"
                            Command="{Binding AppendDigitCommand}"
                            CommandParameter="3" />

                    <Button Content="4"
                            Style="{StaticResource KeypadButton}"
                            Command="{Binding AppendDigitCommand}"
                            CommandParameter="4" />
                    <Button Content="5"
                            Style="{StaticResource KeypadButton}"
                            Command="{Binding AppendDigitCommand}"
                            CommandParameter="5" />
                    <Button Content="6"
                            Style="{StaticResource KeypadButton}"
                            Command="{Binding AppendDigitCommand}"
                            CommandParameter="6" />

                    <Button Content="7"
                            Style="{StaticResource KeypadButton}"
                            Command="{Binding AppendDigitCommand}"
                            CommandParameter="7" />
                    <Button Content="8"
                            Style="{StaticResource KeypadButton}"
                            Command="{Binding AppendDigitCommand}"
                            CommandParameter="8" />
                    <Button Content="9"
                            Style="{StaticResource KeypadButton}"
                            Command="{Binding AppendDigitCommand}"
                            CommandParameter="9" />

                    <Button Style="{StaticResource KeypadActionButton}"
                            Command="{Binding ClearCommand}">
                        <iconPacks:PackIconMaterial Kind="Refresh"
                                                    Width="18" />
                    </Button>
                    <Button Content="0"
                            Style="{StaticResource KeypadButton}"
                            Command="{Binding AppendDigitCommand}"
                            CommandParameter="0" />
                    <Button Style="{StaticResource KeypadActionButton}"
                            Command="{Binding BackspaceCommand}">
                        <iconPacks:PackIconMaterial Kind="BackspaceOutline"
                                                    Width="18" />
                    </Button>
                </UniformGrid>

                <Button Grid.Row="3"
                        Content="CONFIRM GUESTS"
                        Height="56"
                        Margin="0,20,0,0"
                        FontSize="16"
                        FontWeight="Bold"
                        Background="#16A34A"
                        Foreground="White"
                        BorderThickness="0"
                        Command="{Binding ConfirmCommand}">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius"
                                    Value="12" />
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>
    </Border>
</UserControl>
